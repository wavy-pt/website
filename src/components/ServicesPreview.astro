---
import { t, getLocalizedPath } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const scopeItems = i.services.scope;

const services = [
  { key: 'start', data: i.services.start, number: '01', icon: 'ri-radar-line', short: 'Diagnóstico', shortEn: 'Diagnosis' },
  { key: 'boost', data: i.services.boost, number: '02', icon: 'ri-hammer-line', short: 'Obra', shortEn: 'Build' },
  { key: 'flow', data: i.services.flow, number: '03', icon: 'ri-compass-3-line', short: 'Direção', shortEn: 'Direction' },
] as const;
---

<section class="bg-teal py-16 md:py-24 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <!-- Header -->
    <div class="scroll-reveal mb-10 md:mb-12">
      <p class="font-sans text-xs uppercase tracking-widest text-cream/80 mb-3">
        {i.services.label}
      </p>
      <div class="flex flex-col gap-4">
        <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-cream leading-[1.15] max-w-3xl">
          {i.services.title}
        </h2>
        <p class="font-sans text-base text-cream/70 leading-relaxed max-w-2xl">
          {i.services.subtitle}
        </p>
      </div>
    </div>

    <!-- Scope pills -->
    <div class="scroll-reveal flex flex-wrap items-center gap-x-1 gap-y-2 mb-12 md:mb-14">
      {scopeItems.map((item, idx) => (
        <div class="flex items-center gap-1">
          <span class="font-sans text-xs text-cream/70 bg-teal-dark/15 px-3 py-1.5 rounded-full">
            {item}
          </span>
          {idx < scopeItems.length - 1 && (
            <span class="font-sans text-xs text-cream/30 mx-1">&middot;</span>
          )}
        </div>
      ))}
    </div>

    <!-- Interactive Stepper -->
    <div class="scroll-reveal mb-10 md:mb-12">
      <div id="services-stepper" class="relative flex items-center justify-between max-w-3xl mx-auto">
        <!-- Connector line behind nodes -->
        <div class="absolute top-7 md:top-8 left-0 right-0 h-px bg-cream/20 mx-14"></div>

        {services.map(({ number, short, shortEn }, idx) => (
          <button
            type="button"
            data-step={number}
            class:list={[
              'step-btn relative z-10 flex flex-col items-center gap-3 group cursor-pointer',
              idx === 0 ? 'is-active' : '',
            ]}
            aria-label={`Step ${number}`}
          >
            <div class="step-circle w-14 h-14 md:w-16 md:h-16 rounded-full border border-cream/30 bg-teal flex items-center justify-center transition-all duration-300">
              <span class="step-number font-serif text-xl md:text-2xl font-medium text-cream/80 transition-colors duration-300">
                {number}
              </span>
            </div>
            <span class="step-label font-sans text-xs uppercase tracking-wider text-cream/60 transition-colors duration-300 whitespace-nowrap">
              {lang === 'en' ? shortEn : short}
            </span>
          </button>
        ))}
      </div>
    </div>

    <!-- Card area with arrow nav -->
    <div class="scroll-reveal flex items-center gap-3 md:gap-6">
      <!-- Prev arrow -->
      <button
        id="card-prev"
        type="button"
        aria-label="Anterior"
        class="card-nav hidden md:flex shrink-0 w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-cream/10 hover:bg-cream/20 border border-cream/25 text-cream items-center justify-center transition-all duration-300 disabled:opacity-25 disabled:cursor-not-allowed disabled:hover:bg-cream/10"
      >
        <i class="ri-arrow-left-line text-xl"></i>
      </button>

      <!-- Cards -->
      <div id="services-cards" class="relative flex-1 min-h-[580px] sm:min-h-[640px] md:min-h-[600px]">
      {services.map(({ data, number, icon }, idx) => (
        <div
          data-card={number}
          class:list={[
            'service-card absolute inset-0 bg-cream rounded-[24px] md:rounded-[32px] p-6 sm:p-8 md:p-12 overflow-hidden',
            idx === 0 ? 'is-active' : 'position-right',
          ]}
        >
          <!-- Decorative giant number behind content -->
          <span class="absolute -bottom-2 -right-4 font-serif text-[180px] sm:text-[260px] md:text-[400px] font-medium text-teal/10 leading-none select-none pointer-events-none">
            {number}
          </span>

          <!-- Icon badge -->
          <div class="absolute top-6 right-6 md:top-12 md:right-12 w-11 h-11 md:w-14 md:h-14 rounded-full bg-teal/10 flex items-center justify-center">
            <i class={`${icon} text-teal text-lg md:text-2xl`}></i>
          </div>

          <!-- Content -->
          <div class="relative flex flex-col min-h-[400px] md:min-h-[440px] max-w-2xl">
            <span class="inline-flex self-start font-sans text-[11px] uppercase tracking-wider px-3 py-1.5 rounded-full mb-5 md:mb-6 bg-teal text-cream">
              {data.tag}
            </span>

            <p class="font-serif text-xl sm:text-2xl md:text-3xl italic font-medium mb-2 text-teal">
              {data.scriptName}
            </p>
            <h3 class="font-serif text-[2.25rem] leading-[1.05] sm:text-5xl md:text-6xl font-medium mb-5 text-teal-dark md:leading-tight">
              {data.name}
            </h3>
            <p class="font-sans text-base md:text-lg leading-relaxed mb-7 md:mb-8 text-teal-dark/70 max-w-xl">
              {data.desc}
            </p>

            <!-- Price -->
            <div class="mb-7 md:mb-8">
              <div class="flex items-baseline gap-2 flex-wrap">
                {'priceLabel' in data && data.priceLabel && (
                  <span class="font-sans text-xs uppercase tracking-wider text-teal-dark/70">
                    {data.priceLabel}
                  </span>
                )}
                <span class="font-serif text-5xl sm:text-6xl md:text-7xl font-medium text-teal">
                  {data.price}
                </span>
                {'pricePeriod' in data && data.pricePeriod && (
                  <span class="font-sans text-base text-teal-dark/70">
                    {data.pricePeriod}
                  </span>
                )}
              </div>
              {'priceNote' in data && data.priceNote && (
                <p class="font-sans text-xs mt-2 text-teal-dark/75 max-w-xs">
                  {data.priceNote}
                </p>
              )}
            </div>

            <!-- CTA button -->
            <div class="mt-auto">
              <a
                href={getLocalizedPath('/servicos', lang)}
                class="inline-flex items-center gap-2 px-6 py-3 md:px-7 md:py-3.5 rounded-full bg-teal text-cream font-sans font-medium text-sm hover:bg-teal-dark transition-all duration-300 group"
              >
                {data.cta}
                <i class="ri-arrow-right-line transition-transform duration-200 group-hover:translate-x-1"></i>
              </a>
            </div>
          </div>
        </div>
      ))}
      </div>

      <!-- Next arrow -->
      <button
        id="card-next"
        type="button"
        aria-label="Próximo"
        class="card-nav hidden md:flex shrink-0 w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-cream/10 hover:bg-cream/20 border border-cream/25 text-cream items-center justify-center transition-all duration-300 disabled:opacity-25 disabled:cursor-not-allowed disabled:hover:bg-cream/10"
      >
        <i class="ri-arrow-right-line text-xl"></i>
      </button>
    </div>

    <!-- Mobile arrows (below card) -->
    <div class="flex md:hidden items-center justify-center gap-4 mt-6">
      <button
        id="card-prev-mobile"
        type="button"
        aria-label="Anterior"
        class="card-nav-mobile w-11 h-11 rounded-full bg-cream/10 border border-cream/25 text-cream flex items-center justify-center transition-all disabled:opacity-25 disabled:cursor-not-allowed"
      >
        <i class="ri-arrow-left-line text-lg"></i>
      </button>
      <button
        id="card-next-mobile"
        type="button"
        aria-label="Próximo"
        class="card-nav-mobile w-11 h-11 rounded-full bg-cream/10 border border-cream/25 text-cream flex items-center justify-center transition-all disabled:opacity-25 disabled:cursor-not-allowed"
      >
        <i class="ri-arrow-right-line text-lg"></i>
      </button>
    </div>

    <!-- Plan line -->
    <div class="scroll-reveal mt-6 md:mt-8 text-center max-w-3xl mx-auto">
      <p class="font-sans text-base md:text-lg text-cream/95 leading-relaxed">{i.services.planLine}</p>
    </div>
  </div>
</section>

<style>
  .step-btn.is-active .step-circle {
    background-color: #F0EDE4; /* cream */
    border-color: #F0EDE4;
  }
  .step-btn.is-active .step-number {
    color: #2A9090; /* teal */
  }
  .step-btn.is-active .step-label {
    color: #F0EDE4; /* cream */
    font-weight: 500;
  }
  .step-btn:hover .step-circle {
    border-color: #F0EDE4;
  }
  .step-btn:hover .step-number,
  .step-btn:hover .step-label {
    color: #F0EDE4;
  }

  .service-card {
    transition: opacity 900ms cubic-bezier(0.4, 0, 0.2, 1), transform 900ms cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
    transform: translateX(0);
    pointer-events: none;
    will-change: transform, opacity;
  }
  .service-card.position-left {
    opacity: 0;
    transform: translateX(-40px);
  }
  .service-card.position-right {
    opacity: 0;
    transform: translateX(40px);
  }
  .service-card.is-active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }
</style>

<script>
  const stepper = document.getElementById('services-stepper');
  const cards = document.querySelectorAll('.service-card');
  const steps = stepper?.querySelectorAll('.step-btn');
  let currentStep = '01';

  const prevBtns = document.querySelectorAll('#card-prev, #card-prev-mobile');
  const nextBtns = document.querySelectorAll('#card-next, #card-next-mobile');
  const TOTAL = cards.length;

  function updateArrows() {
    const num = parseInt(currentStep, 10);
    prevBtns.forEach((b) => ((b as HTMLButtonElement).disabled = num <= 1));
    nextBtns.forEach((b) => ((b as HTMLButtonElement).disabled = num >= TOTAL));
  }

  function setActive(stepNumber: string) {
    if (stepNumber === currentStep) return;
    const newNum = parseInt(stepNumber, 10);

    steps?.forEach((s) => {
      const el = s as HTMLElement;
      el.classList.toggle('is-active', el.dataset.step === stepNumber);
    });

    cards.forEach((c) => {
      const el = c as HTMLElement;
      const cardNum = parseInt(el.dataset.card || '0', 10);
      el.classList.remove('is-active', 'position-left', 'position-right');
      if (cardNum === newNum) {
        el.classList.add('is-active');
      } else if (cardNum < newNum) {
        el.classList.add('position-left');
      } else {
        el.classList.add('position-right');
      }
    });

    currentStep = stepNumber;
    updateArrows();
  }

  steps?.forEach((s) => {
    s.addEventListener('click', () => {
      const step = (s as HTMLElement).dataset.step;
      if (step) setActive(step);
    });
  });

  prevBtns.forEach((b) => {
    b.addEventListener('click', () => {
      const num = parseInt(currentStep, 10);
      if (num > 1) setActive(String(num - 1).padStart(2, '0'));
    });
  });

  nextBtns.forEach((b) => {
    b.addEventListener('click', () => {
      const num = parseInt(currentStep, 10);
      if (num < TOTAL) setActive(String(num + 1).padStart(2, '0'));
    });
  });

  updateArrows();
</script>
