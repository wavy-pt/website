---
/**
 * Cookie banner + Google Analytics 4 with Consent Mode v2.
 *
 * - Only renders in production AND when PUBLIC_GA_ID is set.
 * - GA4 loads only after the user explicitly accepts.
 * - Default consent state is "denied" (GDPR-friendly).
 * - The user's choice is stored in localStorage and respected on future visits.
 * - The footer can call `window.wavyOpenCookieSettings()` to re-open the banner.
 */
import { getLangFromUrl } from '../i18n';
import { isProd } from '../lib/env';

const gaId = import.meta.env.PUBLIC_GA_ID;
const enabled = isProd && Boolean(gaId);

const lang = getLangFromUrl(Astro.url);
const isEn = lang === 'en';
const privacyHref = isEn ? '/en/privacy' : '/privacidade';

const copy = isEn
  ? {
      message:
        'We use cookies to understand how the site is used and improve it. Only with your consent.',
      accept: 'Accept',
      reject: 'Reject',
      learn: 'Privacy policy',
    }
  : {
      message:
        'Usamos cookies para perceber como o site é usado e melhorá-lo. Só com o teu consentimento.',
      accept: 'Aceitar',
      reject: 'Recusar',
      learn: 'Política de privacidade',
    };
---

{enabled && (
  <>
    {/* Pre-load Consent Mode defaults BEFORE GA loads.
        Importante: com is:inline o Astro NÃO processa o conteúdo, tem de
        ser JavaScript puro, sem template literal envolvente. */}
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        wait_for_update: 500,
      });
      gtag('js', new Date());
    </script>

    <div
      id="cookie-banner"
      data-state="hidden"
      class="fixed bottom-4 left-4 right-4 md:bottom-6 md:left-1/2 md:right-auto md:-translate-x-1/2 md:max-w-2xl md:w-[calc(100%-3rem)] z-[70] data-[state=hidden]:hidden"
    >
      <div class="bg-teal-deep text-cream rounded-2xl shadow-2xl p-6 md:p-8 border border-cream/10">
        <div class="flex flex-col md:flex-row md:items-center md:gap-8">
          <p class="font-sans text-sm md:text-base leading-relaxed mb-5 md:mb-0 md:flex-1">
            {copy.message}
          </p>
          <div class="flex flex-wrap items-center gap-3 shrink-0">
            <button
              type="button"
              data-cookie-action="accept"
              class="inline-flex items-center justify-center font-sans text-sm font-medium px-6 py-2.5 rounded-full bg-cream text-teal-dark hover:bg-offwhite transition-colors whitespace-nowrap"
            >
              {copy.accept}
            </button>
            <button
              type="button"
              data-cookie-action="reject"
              class="inline-flex items-center justify-center font-sans text-sm font-medium px-6 py-2.5 rounded-full border border-cream/30 text-cream hover:bg-cream/10 transition-colors whitespace-nowrap"
            >
              {copy.reject}
            </button>
          </div>
        </div>
        <div class="mt-4 md:mt-3 md:pt-3 md:border-t md:border-cream/10">
          <a
            href={privacyHref}
            class="font-sans text-xs text-cream hover:text-cream underline underline-offset-2"
          >
            {copy.learn}
          </a>
        </div>
      </div>
    </div>

    <script define:vars={{ gaId }}>
      const STORAGE_KEY = 'wavy-cookie-consent';

      function safeGtag() {
        if (typeof window.gtag === 'function') {
          window.gtag.apply(window, arguments);
        }
      }

      function loadGa() {
        if (document.querySelector('script[data-ga="loaded"]')) return;
        const s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
        s.dataset.ga = 'loaded';
        document.head.appendChild(s);
        safeGtag('config', gaId, { anonymize_ip: true });
      }

      function setBannerState(state) {
        const el = document.getElementById('cookie-banner');
        if (el) el.dataset.state = state;
      }

      function applyConsent(value) {
        try {
          localStorage.setItem(STORAGE_KEY, value);
        } catch (_) {
          // localStorage pode falhar em modo privado de alguns browsers
        }
        if (value === 'accepted') {
          safeGtag('consent', 'update', { analytics_storage: 'granted' });
          loadGa();
        } else {
          safeGtag('consent', 'update', { analytics_storage: 'denied' });
        }
        setBannerState('hidden');
      }

      function init() {
        const banner = document.getElementById('cookie-banner');
        if (!banner) return;

        // Initial state — mostrar banner se ainda não houve escolha
        let stored = null;
        try { stored = localStorage.getItem(STORAGE_KEY); } catch (_) {}

        if (stored === 'accepted') {
          safeGtag('consent', 'update', { analytics_storage: 'granted' });
          loadGa();
        } else if (stored === 'rejected') {
          // Already declined — banner fica hidden
        } else {
          setBannerState('visible');
        }

        // Wire up buttons via event delegation
        banner.addEventListener('click', function (e) {
          const target = e.target instanceof Element ? e.target : null;
          if (!target) return;
          const btn = target.closest('[data-cookie-action]');
          if (!btn) return;
          const action = btn.getAttribute('data-cookie-action');
          if (action === 'accept') applyConsent('accepted');
          else if (action === 'reject') applyConsent('rejected');
        });

        // Expose a global helper so the footer can re-open the banner
        window.wavyOpenCookieSettings = function () {
          try { localStorage.removeItem(STORAGE_KEY); } catch (_) {}
          setBannerState('visible');
        };
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    </script>
  </>
)}
