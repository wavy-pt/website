---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const w = t(lang).contactPage.whereWeAre;
---

<section class="bg-offwhite pb-20 md:pb-28">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <p class="font-sans text-xs uppercase tracking-widest text-teal mb-6">{w.label}</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {w.blocks.map((b) => (
          <div class="bg-cream rounded-[24px] p-6 md:p-7">
            <div class="w-11 h-11 rounded-full bg-teal/10 text-teal flex items-center justify-center mb-4">
              <i class={`${b.icon} text-lg`} aria-hidden="true"></i>
            </div>
            <h3 class="font-serif text-lg font-medium text-teal-dark mb-1.5">{b.title}</h3>
            <p class="font-sans text-sm text-muted leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
