---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).contactPage.page;
---

<section class="pt-[72px] bg-offwhite">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-12 md:py-16">
    <div class="scroll-reveal text-center max-w-2xl mx-auto">
      <p class="font-serif italic text-teal text-sm mb-4">
        {i.label}
      </p>
      <h1 class="font-serif text-[2.25rem] sm:text-4xl md:text-5xl lg:text-6xl font-medium text-teal-dark leading-[1.1] mb-5">
        {i.title}
      </h1>
      <p class="font-sans text-base text-muted leading-relaxed">
        {i.subtitle}
      </p>
    </div>
  </div>
</section>
