---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).contactPage.talk;
---

<section class="bg-offwhite py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <h2 class="font-serif text-2xl md:text-3xl font-medium text-teal-dark text-center mb-12">
        {i.title}
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-2xl mx-auto">
        <!-- Email -->
        <a
          href={`mailto:${i.email}`}
          class="bg-cream rounded-[24px] p-8 flex flex-col items-center text-center transition-transform duration-300 hover:-translate-y-1 group"
          aria-label={`${i.emailLabel}: ${i.email}`}
        >
          <div class="w-12 h-12 flex items-center justify-center rounded-full bg-offwhite text-teal mb-5" aria-hidden="true">
            <i class="ri-mail-line text-xl"></i>
          </div>
          <p class="font-sans text-xs uppercase tracking-wider text-muted mb-2">{i.emailLabel}</p>
          <p class="font-sans text-sm text-teal-dark group-hover:text-teal transition-colors">
            {i.email}
          </p>
        </a>

        <!-- Instagram -->
        <a
          href="https://instagram.com/wavy.digital.pt"
          target="_blank"
          rel="nofollow noreferrer"
          class="bg-cream rounded-[24px] p-8 flex flex-col items-center text-center transition-transform duration-300 hover:-translate-y-1 group"
          aria-label={`${i.instagramLabel}: ${i.instagram}`}
        >
          <div class="w-12 h-12 flex items-center justify-center rounded-full bg-offwhite text-teal mb-5" aria-hidden="true">
            <i class="ri-instagram-line text-xl"></i>
          </div>
          <p class="font-sans text-xs uppercase tracking-wider text-muted mb-2">{i.instagramLabel}</p>
          <p class="font-sans text-sm text-teal-dark group-hover:text-teal transition-colors">
            {i.instagram}
          </p>
        </a>
      </div>
    </div>
  </div>
</section>
