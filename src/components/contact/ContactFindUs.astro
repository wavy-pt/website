---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).contactPage.findUs;
---

<section class="bg-cream py-10 md:py-12">
  <div class="max-w-4xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal flex flex-col md:flex-row items-center justify-center gap-8 md:gap-16">
      <!-- Location -->
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 flex items-center justify-center rounded-full bg-offwhite text-teal shrink-0" aria-hidden="true">
          <i class="ri-map-pin-line text-lg"></i>
        </div>
        <div>
          <p class="font-sans text-xs uppercase tracking-wider text-muted">{i.locationLabel}</p>
          <p class="font-sans text-sm text-teal-dark">{i.location}</p>
        </div>
      </div>

      <!-- Divider -->
      <div class="hidden md:block w-px h-10 bg-teal-dark/10" aria-hidden="true"></div>

      <!-- Hours -->
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 flex items-center justify-center rounded-full bg-offwhite text-teal shrink-0" aria-hidden="true">
          <i class="ri-time-line text-lg"></i>
        </div>
        <div>
          <p class="font-sans text-xs uppercase tracking-wider text-muted">{i.hoursLabel}</p>
          <p class="font-sans text-sm text-teal-dark">{i.hours}</p>
        </div>
      </div>
    </div>
  </div>
</section>
