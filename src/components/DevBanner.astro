---
import { isDev } from '../lib/env';

if (!isDev) return null;
---

<div
  class="fixed bottom-4 left-4 z-[60] pointer-events-none flex items-center gap-2 px-3 py-1.5 rounded-full bg-teal-dark text-cream text-[11px] font-sans font-medium tracking-wider uppercase shadow-lg"
  aria-hidden="true"
>
  <span class="relative flex h-2 w-2">
    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cream opacity-75"></span>
    <span class="relative inline-flex rounded-full h-2 w-2 bg-cream"></span>
  </span>
  Ambiente de desenvolvimento
</div>
