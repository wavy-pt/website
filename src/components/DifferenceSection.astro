---
import { t } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const headers = i.difference.headers;
const rows = i.difference.rows;
---

<section class="bg-offwhite py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <!-- Header -->
      <div class="text-center mb-10 md:mb-12">
        <p class="font-sans text-xs uppercase tracking-widest text-teal mb-3">{i.difference.label}</p>
        <h2 class="font-serif text-4xl md:text-5xl font-medium text-teal-dark leading-[1.15] mb-4 max-w-2xl mx-auto">
          {i.difference.title}
        </h2>
        <p class="font-sans text-base text-muted max-w-xl mx-auto leading-relaxed">
          {i.difference.subtitle}
        </p>
      </div>

      <!-- Table -->
      <div class="bg-cream rounded-[28px] overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[680px]">
            <thead>
              <tr>
                {headers.map((h, idx) => (
                  <th
                    class:list={[
                      'text-left font-sans text-sm font-medium px-6 py-5',
                      idx === 3
                        ? 'bg-teal text-white rounded-tl-[20px] rounded-tr-[20px]'
                        : 'text-teal-dark',
                    ]}
                  >
                    {idx === 3 ? (
                      <span class="font-serif text-xl font-medium">{h}</span>
                    ) : (
                      h
                    )}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {rows.map((row) => (
                <tr class="border-t border-teal-dark/5">
                  <td class="font-sans text-sm font-medium text-teal-dark px-6 py-5 w-[140px]">
                    {row.dim}
                  </td>
                  <td class="font-sans text-sm text-muted px-6 py-5">{row.agency}</td>
                  <td class="font-sans text-sm text-muted px-6 py-5">{row.freelance}</td>
                  <td class="font-sans text-sm font-medium text-teal-dark bg-teal/10 px-6 py-5">
                    {row.wavy}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>
