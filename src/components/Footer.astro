---
import { t } from '../i18n';
import type { Lang } from '../i18n';
import { getNavLinks } from '../lib/nav';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);

const navLinks = getNavLinks(lang);

// Crédito de desenvolvimento (ADDS) — link dependente do idioma.
const addsUrl = lang === 'en' ? 'https://addssolutions.com/en/' : 'https://addssolutions.com/';

// Livro de Reclamações eletrónico. Obrigatório por lei em local visível e destacado
// do site (DL 156/2005, art. 5.º-B n.º 2, aditado pelo DL 74/2017) — não remover.
// Sem variante por idioma: a plataforma troca para inglês por sessão, sem mudar de
// URL (o botão "English" lá dentro), e /en/inicio dá 404. Ambos apontam para o mesmo.
const livroReclamacoesUrl = 'https://www.livroreclamacoes.pt/inicio';
---

<footer class="bg-teal-deep text-cream">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-16 md:py-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8">
      <!-- Brand -->
      <div class="md:col-span-2">
        <img src="/logo-wavy-tight.svg" alt="Wavy" class="h-10 w-auto brightness-0 invert opacity-95" />
        <p class="font-sans text-base italic text-cream mb-6 max-w-xs leading-relaxed mt-4 font-medium">
          {i.footer.tagline}
        </p>
        <div class="flex items-center gap-4">
          <a
            href="https://instagram.com/wavy.digital.pt"
            target="_blank"
            rel="nofollow noreferrer"
            aria-label="Instagram da Wavy"
            class="w-11 h-11 flex items-center justify-center rounded-full border border-cream/50 text-cream hover:text-cream hover:border-cream/80 transition-all duration-200"
          >
            <i class="ri-instagram-line text-lg" aria-hidden="true"></i>
          </a>
          <a
            href="https://facebook.com/wavy.digital.pt"
            target="_blank"
            rel="nofollow noreferrer"
            aria-label="Facebook da Wavy"
            class="w-11 h-11 flex items-center justify-center rounded-full border border-cream/50 text-cream hover:text-cream hover:border-cream/80 transition-all duration-200"
          >
            <i class="ri-facebook-line text-lg" aria-hidden="true"></i>
          </a>
          <a
            href="mailto:geral@wavy.pt"
            aria-label="Enviar email para geral@wavy.pt"
            class="w-11 h-11 flex items-center justify-center rounded-full border border-cream/50 text-cream hover:text-cream hover:border-cream/80 transition-all duration-200"
          >
            <i class="ri-mail-line text-lg" aria-hidden="true"></i>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <p class="font-sans text-xs uppercase tracking-widest text-cream mb-5">
          {i.footer.navTitle}
        </p>
        <nav class="flex flex-col gap-1">
          {navLinks.map((link) => (
            <a
              href={link.to}
              class="font-sans text-sm text-cream hover:text-cream transition-colors duration-200 py-2 -my-1 inline-block"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <p class="font-sans text-xs uppercase tracking-widest text-cream mb-5">
          {i.footer.contactTitle}
        </p>
        <div class="flex flex-col gap-1">
          <a
            href="mailto:geral@wavy.pt"
            class="font-sans text-sm text-cream hover:text-cream transition-colors duration-200 py-2 -my-1 inline-block"
          >
            geral@wavy.pt
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-cream/20 flex flex-col sm:flex-row items-center justify-between gap-2 sm:gap-4">
      <p class="font-sans text-sm text-cream py-2">{i.footer.rights}</p>
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-1">
        <a
          href={lang === 'en' ? '/en/privacy' : '/privacidade'}
          class="font-sans text-sm text-cream hover:text-cream transition-colors py-2 inline-block"
        >
          {lang === 'en' ? 'Privacy policy' : 'Política de privacidade'}
        </a>
        <button
          type="button"
          onclick="window.wavyOpenCookieSettings && window.wavyOpenCookieSettings()"
          class="font-sans text-sm text-cream hover:text-cream transition-colors cursor-pointer py-2"
        >
          {lang === 'en' ? 'Manage cookies' : 'Gerir cookies'}
        </button>
        <a
          href={livroReclamacoesUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-sans text-sm text-cream hover:text-cream transition-colors py-2 inline-block"
        >
          {lang === 'en' ? 'Complaints book' : 'Livro de Reclamações'}
        </a>
      </div>
    </div>

    <!-- Crédito de desenvolvimento (ADDS) -->
    <p class="mt-8 text-center font-sans text-xs text-cream">
      {lang === 'en' ? 'Developed by' : 'Desenvolvido pela'}{' '}
      <a
        href={addsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium underline underline-offset-2 decoration-cream/40 hover:decoration-cream transition-colors"
      >ADDS</a>
    </p>
  </div>
</footer>
