---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).casesPage.page;
---

<section class="pt-[72px] bg-offwhite">
  <div class="max-w-7xl mx-auto px-6 md:px-10 py-14 md:py-20">
    <div class="scroll-reveal">
      <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-teal mb-5">
        {i.label}
      </p>
      <h1 class="font-serif text-[2.25rem] sm:text-4xl md:text-5xl lg:text-[4.5rem] font-medium text-teal-dark leading-[1.05] mb-5">
        {i.titleLine1}
        <br />
        {i.titleLine2}
        <br />
        {i.titleLine3}
      </h1>
      <p class="font-sans text-base text-muted leading-relaxed max-w-xl">
        {i.subtitle}
      </p>
    </div>
  </div>
</section>
