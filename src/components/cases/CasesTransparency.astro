---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang).casesPage.transparency;
---

<section class="bg-offwhite pb-4 md:pb-8">
  <div class="max-w-3xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal border-l-2 border-teal/40 pl-6 md:pl-8">
      <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-teal mb-3">{tr.label}</p>
      <p class="font-sans text-sm md:text-base text-muted leading-relaxed">{tr.body}</p>
    </div>
  </div>
</section>
