---
import { Image } from 'astro:assets';
import { t, getLocalizedPath } from '../../i18n';
import type { Lang } from '../../i18n';
import { schedulingHref, schedulingIsExternal } from '../../lib/env';
import bastidoresImage from '../../assets/wavy-bastidores.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).casesPage.cta;
// "Marcar o meu Raio-X" → Calendly (marcação direta).
const ctaHref = schedulingHref(getLocalizedPath('/contacto', lang));
---

<section class="bg-offwhite py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal bg-teal rounded-[28px] overflow-hidden">
      <div class="grid grid-cols-1 lg:grid-cols-12">
        <!-- Image -->
        <div class="lg:col-span-5 relative">
          <div class="h-56 lg:h-full relative">
            <Image
              src={bastidoresImage}
              alt="Wavy brand strategy consultation"
              class="w-full h-full object-cover object-top"
              loading="lazy"
              widths={[480, 720, 960]}
              sizes="(min-width: 1024px) 41vw, 100vw"
              quality={82}
            />
          </div>
        </div>

        <!-- Content -->
        <div class="lg:col-span-7 p-8 md:p-12 flex flex-col justify-center">
          <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl font-medium text-cream mb-4 leading-tight">
            {i.title}
          </h2>
          <p class="font-sans text-base text-cream/85 leading-relaxed mb-6 max-w-md">
            {i.subtitle}
          </p>
          <div>
            <a
              href={ctaHref}
              target={schedulingIsExternal ? '_blank' : undefined}
              rel={schedulingIsExternal ? 'noopener noreferrer' : undefined}
              class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm px-7 py-3.5 md:px-8 md:py-4 rounded-full bg-cream text-teal hover:bg-offwhite transition-all duration-300 whitespace-nowrap"
            >
              <i class="ri-calendar-check-line" aria-hidden="true"></i>
              {i.button}
            </a>
          </div>
        </div>
      </div>
    </div>

    {i.manifesto && (
      <p class="scroll-reveal text-center font-serif text-lg md:text-2xl italic text-teal-dark/80 max-w-2xl mx-auto mt-12 md:mt-16">
        {i.manifesto}
      </p>
    )}
  </div>
</section>
