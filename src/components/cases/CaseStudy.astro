---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Carousel from './Carousel.astro';
import { t } from '../../i18n';
import type { Lang } from '../../i18n';
import bastidoresImage from '../../assets/wavy-bastidores.jpg';
import heroImage from '../../assets/wavy-hero.jpg';
import ctaImage from '../../assets/CTA.jpg';
// Imagens reais dos casos
import veraMain from '../../assets/cases/vera-main.jpg';
import veraFeedAntes from '../../assets/cases/vera-feed-antes.jpg';
import veraFeedDepois from '../../assets/cases/vera-feed-depois.jpg';
import addsLogo from '../../assets/cases/adds-logo.png';
import addsMonogram from '../../assets/cases/adds-monogram.png';
import addsPost1 from '../../assets/cases/adds-post-1.jpg';
import addsPost2 from '../../assets/cases/adds-post-2.jpg';
import addsWebsite from '../../assets/cases/adds-website.jpg';
import anaCamomila from '../../assets/cases/ana-camomila.jpg';
import anaGranola from '../../assets/cases/ana-granola.jpg';
import anaAzeitonas from '../../assets/cases/ana-azeitonas.jpg';
import veraLogoAntigo from '../../assets/cases/vera-logo-antigo.jpg';
import veraLogoBa from '../../assets/cases/vera-logo-ba.jpg';
import veraFeedBa from '../../assets/cases/vera-feed-ba.jpg';

interface Props {
  lang: Lang;
  index: number;
}

const { lang, index } = Astro.props;
const cp = t(lang).casesPage;
const items = cp.items;
const item = items[index];

if (!item) throw new Error(`CaseStudy index ${index} out of range`);

const imageMap: Record<string, typeof bastidoresImage> = {
  'vera-main': veraMain,
  'vera-logo-antigo': veraLogoAntigo,
  'vera-logo-ba': veraLogoBa,
  'vera-feed-ba': veraFeedBa,
  'vera-feed-antes': veraFeedAntes,
  'vera-feed-depois': veraFeedDepois,
  'adds-logo': addsLogo,
  'adds-monogram': addsMonogram,
  'adds-post-1': addsPost1,
  'adds-post-2': addsPost2,
  'adds-website': addsWebsite,
  'ana-camomila': anaCamomila,
  'ana-granola': anaGranola,
  'ana-azeitonas': anaAzeitonas,
  // legados (fallback)
  bastidores: bastidoresImage,
  hero: heroImage,
  cta: ctaImage,
};
const img = imageMap[item.imageKey || 'bastidores'];
const detail = item.detail;
const ui = cp.ui;
// Galeria: com 2 imagens (ex.: antes/depois), mostra 2 colunas maiores; com 3+, mantém 3.
const galleryCols = detail?.gallery?.length === 2 ? 'grid-cols-1 sm:grid-cols-2' : 'grid-cols-2 md:grid-cols-3';

// Carrosséis: agrupa as imagens de cada subpasta de /carrosseis, ordenadas por nome (1.jpg, 2.jpg, …)
const carouselFiles = import.meta.glob('../../assets/cases/carrosseis/*/*.{jpg,png}', {
  eager: true,
  import: 'default',
}) as Record<string, ImageMetadata>;
const carouselRegistry: Record<string, ImageMetadata[]> = {};
Object.keys(carouselFiles)
  .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
  .forEach((path) => {
    const m = path.match(/carrosseis\/([^/]+)\//);
    if (!m) return;
    (carouselRegistry[m[1]] ??= []).push(carouselFiles[path]);
  });

const isEven = index % 2 === 0;
---

<section id={`caso-${index}`} class="bg-offwhite py-8 md:py-12 scroll-mt-24">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <!-- Separator line -->
      <div class="border-t border-cream mb-8 md:mb-12" aria-hidden="true"></div>

      <!-- Main grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-14">
        <!-- Image -->
        <div class:list={['lg:col-span-5', isEven ? 'lg:order-1' : 'lg:order-2']}>
          <div class="bg-cream rounded-[24px] overflow-hidden relative">
            <div class="aspect-[4/5] relative">
              <Image
                src={img}
                alt={item.imageCaption}
                class="w-full h-full object-cover object-center"
                loading="lazy"
                widths={[480, 720, 960]}
                sizes="(min-width: 1024px) 41vw, 100vw"
                quality={82}
              />
            </div>
            <div class="absolute bottom-4 left-4">
              <span class="inline-flex font-sans text-[11px] text-muted bg-offwhite/90 backdrop-blur-sm px-4 py-2 rounded-full">
                [{item.imageCaption}]
              </span>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div class:list={['lg:col-span-7', isEven ? 'lg:order-2' : 'lg:order-1']}>
          <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-muted mb-3">
            {item.metadata}
          </p>

          <h2 class="font-serif text-2xl md:text-3xl lg:text-[2.25rem] font-medium text-teal-dark leading-[1.15] mb-5">
            {item.headlineBefore}{' '}
            <em class="font-serif italic font-medium text-teal">{item.headlineHighlight}</em>
            {item.headlineAfter ? ' ' + item.headlineAfter : ''}
          </h2>

          <p class="font-sans text-sm md:text-base text-teal-dark/80 leading-relaxed mb-6 max-w-xl">
            {item.description}
          </p>

          <!-- Stats row -->
          <div class="border-t border-cream pt-5 mb-6">
            <div class="grid grid-cols-3 gap-4 md:gap-8">
              {item.stats.map((stat) => (
                <div>
                  <p class="font-serif text-xl md:text-2xl lg:text-3xl font-medium text-teal mb-1">
                    {stat.value}
                  </p>
                  <p class="font-sans text-[11px] md:text-xs text-muted leading-snug">
                    {stat.label}
                  </p>
                </div>
              ))}
            </div>
          </div>

          <!-- Quote -->
          <div class="border-t border-cream pt-5">
            <div class="border-l-2 border-teal pl-5">
              <blockquote class="font-serif text-sm md:text-base italic text-teal-dark/80 leading-relaxed mb-3">
                &ldquo;{item.quote}&rdquo;
              </blockquote>
              <p class="font-sans text-[11px] uppercase tracking-[0.15em] text-muted">
                {item.quoteAuthor}
              </p>
            </div>
          </div>

          {detail && (
            <div class="mt-7">
              <button
                type="button"
                data-case-open={index}
                aria-haspopup="dialog"
                class="group inline-flex items-center gap-2 font-sans font-medium text-sm px-7 py-3.5 rounded-full bg-teal-dark text-cream hover:bg-teal transition-all duration-300"
              >
                {ui.seeMore}
                <i
                  class="ri-arrow-right-up-line transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                  aria-hidden="true"
                ></i>
              </button>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

{detail && (
  <dialog
    data-case-modal={index}
    aria-label={item.quoteAuthor}
    class="fixed inset-0 w-full h-full max-w-none max-h-none m-0 p-0 bg-transparent backdrop:bg-teal-dark/60 backdrop:backdrop-blur-sm"
  >
    <div class="min-h-full w-full flex items-center justify-center p-4 sm:p-6">
      <div
        data-case-panel-wrap
        class="relative w-full max-w-4xl max-h-[88vh] overflow-hidden rounded-[28px] bg-offwhite text-teal-dark shadow-2xl"
      >
        <button
          type="button"
          data-case-close
          aria-label={ui.close}
          class="absolute top-4 right-4 z-20 w-10 h-10 rounded-full bg-teal-dark text-cream hover:bg-teal flex items-center justify-center shadow-md transition-colors"
        >
          <i class="ri-close-line text-xl" aria-hidden="true"></i>
        </button>

        <div class="max-h-[88vh] overflow-y-auto px-6 sm:px-8 md:px-10 pt-16 pb-8 md:pb-10">
          <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-muted mb-3">
            {item.metadata}
          </p>
          <h3 class="font-serif text-2xl md:text-3xl lg:text-4xl font-medium text-teal-dark leading-[1.15] mb-5 max-w-2xl">
            {item.headlineBefore}{' '}
            <em class="font-serif italic font-medium text-teal">{item.headlineHighlight}</em>
            {item.headlineAfter ? ' ' + item.headlineAfter : ''}
          </h3>

          {detail.services && (
            <div class="flex flex-wrap gap-2 mb-8">
              {detail.services.map((s) => (
                <span class="font-sans text-xs px-3 py-1.5 rounded-full bg-teal/10 text-teal-dark">{s}</span>
              ))}
            </div>
          )}

          {detail.gallery && (
            <div class="mb-8">
              <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-teal-deep mb-3">{ui.galleryLabel}</p>
              <div class:list={['grid gap-3 md:gap-4', galleryCols]}>
                {detail.gallery.map((g) => {
                  const gimg = imageMap[g.imageKey || 'bastidores'];
                  return (
                    <figure class="rounded-2xl overflow-hidden bg-cream">
                      <div class="aspect-[4/5] relative">
                        <Image
                          src={gimg}
                          alt={g.caption}
                          class="w-full h-full object-cover object-center"
                          loading="lazy"
                          widths={[320, 480]}
                          sizes="320px"
                          quality={78}
                        />
                      </div>
                      <figcaption class="font-sans text-[11px] text-muted px-3 py-2">{g.caption}</figcaption>
                    </figure>
                  );
                })}
              </div>
            </div>
          )}

          {detail.carousels && detail.carousels.length > 0 && (
            <div class="mb-10">
              <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-teal-deep mb-5">{ui.carouselsLabel}</p>
              <div class="grid gap-10 sm:grid-cols-2 sm:gap-6 md:gap-8 justify-items-center">
                {detail.carousels.map((c) => {
                  const imgs = carouselRegistry[c.key] || [];
                  if (!imgs.length) return null;
                  return <Carousel images={imgs} lang={lang} label={c.label} />;
                })}
              </div>
            </div>
          )}

          {detail.intro && (
            <p class="font-sans text-base md:text-lg text-teal-dark/85 leading-relaxed mb-8 max-w-2xl">
              {detail.intro}
            </p>
          )}

          {detail.sections && (
            <div class="grid gap-6 sm:grid-cols-3 mb-10">
              {detail.sections.map((sec) => (
                <div>
                  <h4 class="font-serif text-lg font-medium text-teal-dark mb-2">{sec.title}</h4>
                  <p class="font-sans text-sm text-muted leading-relaxed">{sec.body}</p>
                </div>
              ))}
            </div>
          )}

          {detail.stats && (
            <div class="border-t border-cream pt-6 mb-8">
              <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-teal-deep mb-4">{ui.resultsLabel}</p>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-5 md:gap-6">
                {detail.stats.map((stat) => (
                  <div>
                    <p class="font-serif text-2xl md:text-3xl font-medium text-teal mb-1">{stat.value}</p>
                    <p class="font-sans text-[11px] md:text-xs text-muted leading-snug">{stat.label}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <div class="border-l-2 border-teal pl-5">
            <blockquote class="font-serif text-base md:text-lg italic text-teal-dark/80 leading-relaxed mb-3">
              &ldquo;{item.quote}&rdquo;
            </blockquote>
            <p class="font-sans text-[11px] uppercase tracking-[0.15em] text-muted">{item.quoteAuthor}</p>
          </div>
        </div>
      </div>
    </div>
  </dialog>
)}

<script>
  function initCaseModals() {
    document.querySelectorAll('[data-case-open]').forEach((btn) => {
      if (btn.getAttribute('data-bound') === 'true') return;
      btn.setAttribute('data-bound', 'true');
      btn.addEventListener('click', () => {
        const idx = btn.getAttribute('data-case-open');
        const modal = document.querySelector('dialog[data-case-modal="' + idx + '"]');
        if (modal && typeof modal.showModal === 'function') {
          modal.showModal();
          document.documentElement.style.overflow = 'hidden';
        }
      });
    });

    document.querySelectorAll('dialog[data-case-modal]').forEach((modal) => {
      if (modal.getAttribute('data-bound') === 'true') return;
      modal.setAttribute('data-bound', 'true');

      const closeBtn = modal.querySelector('[data-case-close]');
      if (closeBtn) closeBtn.addEventListener('click', () => modal.close());

      modal.addEventListener('click', (e) => {
        const wrap = modal.querySelector('[data-case-panel-wrap]');
        if (wrap && e.target instanceof Node && !wrap.contains(e.target)) {
          modal.close();
        }
      });

      modal.addEventListener('close', () => {
        document.documentElement.style.overflow = '';
      });
    });
  }

  document.addEventListener('astro:page-load', initCaseModals);
  document.addEventListener('DOMContentLoaded', initCaseModals);
  initCaseModals();
</script>
