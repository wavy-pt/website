---
import { t } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const cards = i.forWho.cards;

const icons = ['ri-question-mark', 'ri-sparkling-line', 'ri-flashlight-line'];
---

<section class="bg-offwhite py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <!-- Header -->
      <div class="mb-8 md:mb-10">
        <p class="font-sans text-xs uppercase tracking-widest text-teal-dark mb-3">{i.forWho.label}</p>
        <div class="flex flex-col gap-4">
          <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-teal-dark leading-[1.15] max-w-3xl">
            {i.forWho.title}
          </h2>
          <p class="font-sans text-base text-muted leading-relaxed max-w-xl">
            {i.forWho.subtitle}
          </p>
        </div>
      </div>

      <!-- Cards grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {cards.map((card, idx) => (
          <div
            class="group relative bg-cream hover:bg-teal rounded-[24px] p-6 md:p-7 flex flex-col min-h-[260px] transition-all duration-500 hover:-translate-y-1"
          >
            <span class="inline-flex self-start font-sans text-[11px] uppercase tracking-wider text-teal-dark/80 bg-offwhite border border-teal-deep/10 group-hover:text-offwhite group-hover:bg-teal-deep/30 group-hover:border-offwhite/20 px-3 py-1.5 rounded-full mb-5 transition-all duration-500">
              {card.pill}
            </span>

            <span class="absolute top-7 right-7 md:right-8 font-serif text-7xl md:text-8xl font-medium text-teal/20 group-hover:text-offwhite leading-none select-none transition-all duration-500">
              {card.number}
            </span>

            <div class="w-11 h-11 flex items-center justify-center rounded-full bg-teal/10 text-teal group-hover:bg-offwhite/15 group-hover:text-offwhite mb-4 transition-all duration-500">
              <i class={`${icons[idx]} text-xl`}></i>
            </div>

            <h3 class="font-serif text-xl md:text-2xl font-medium text-teal-dark group-hover:text-offwhite mb-2 leading-snug transition-all duration-500">
              {card.title}
            </h3>
            <p class="font-sans text-sm text-muted group-hover:text-offwhite/85 leading-relaxed mb-4 flex-1 transition-all duration-500">
              {card.desc}
            </p>

            <div class="border-t border-teal-deep/10 group-hover:border-offwhite/20 pt-4 mt-auto transition-all duration-500">
              <p class="font-serif text-sm italic text-teal-dark group-hover:text-offwhite transition-all duration-500">{card.quote}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Footer text -->
      <div class="mt-6 md:mt-8 text-center max-w-3xl mx-auto">
        <p class="font-serif text-base md:text-lg text-teal-dark leading-relaxed">
          {i.forWho.footer}
        </p>
      </div>
    </div>
  </div>
</section>
