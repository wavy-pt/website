---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).servicesPage.process;
---

<section class="bg-cream py-14 md:py-20">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <!-- Header -->
      <div class="mb-10 md:mb-14">
        <p class="font-sans text-xs uppercase tracking-widest text-teal-dark mb-3">
          {i.label}
        </p>
        <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-teal-dark leading-[1.15] mb-4">
          {i.title}
        </h2>
        <p class="font-sans text-base text-teal-dark/70 leading-relaxed max-w-xl">
          {i.subtitle}
        </p>
      </div>

      <!-- Steps -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-8 relative">
        {i.steps.map((step, idx) => (
          <div class="relative flex flex-col">
            <!-- Connector line (desktop only, between cards) -->
            {idx < i.steps.length - 1 && (
              <div class="hidden md:block absolute top-5 left-[calc(50%+28px)] w-[calc(100%-56px)] h-px bg-teal-dark/15" aria-hidden="true"></div>
            )}

            <!-- Number circle + connector mobile -->
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-full bg-teal flex items-center justify-center flex-shrink-0">
                <span class="font-serif text-base font-bold text-cream">
                  {step.number}
                </span>
              </div>
              <div class="h-px bg-teal-dark/15 flex-1 md:hidden" aria-hidden="true"></div>
            </div>

            <!-- Content -->
            <h3 class="font-serif text-xl font-medium text-teal-dark mb-2">
              {step.title}
            </h3>
            <p class="font-sans text-sm text-teal-dark/60 leading-relaxed">
              {step.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
