---
import { t, getLocalizedPath } from '../../i18n';
import type { Lang } from '../../i18n';
import { schedulingHref, schedulingIsExternal } from '../../lib/env';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const m = t(lang).servicesPage.method;
// "Fazer o Raio-X" → Calendly (marcar a conversa que inicia o diagnóstico).
const ctaHref = schedulingHref(getLocalizedPath('/contacto', lang));
---

<section class="bg-white py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <!-- Header -->
    <div class="scroll-reveal max-w-3xl mb-12 md:mb-16">
      <p class="font-sans text-xs uppercase tracking-widest text-teal mb-3">{m.label}</p>
      <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-teal-dark leading-[1.15] mb-4">
        {m.title}
      </h2>
      <p class="font-sans text-base md:text-lg text-muted leading-relaxed">{m.subtitle}</p>
    </div>

    <!-- Princípios -->
    <div class="scroll-reveal flex flex-col max-w-4xl">
      {m.principles.map((pr) => (
        <div class="grid grid-cols-[auto_1fr] gap-5 md:gap-8 items-start border-t border-cream py-8 md:py-10">
          <span class="font-serif text-4xl md:text-6xl font-medium text-teal/30 leading-none">{pr.number}</span>
          <div>
            <h3 class="font-serif text-xl md:text-2xl font-medium text-teal-dark leading-snug mb-3">{pr.title}</h3>
            <p class="font-sans text-base text-muted leading-relaxed max-w-2xl">{pr.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Fecho + CTA -->
    <div class="scroll-reveal mt-12 md:mt-16 max-w-3xl">
      <p class="font-serif text-lg md:text-xl italic text-teal-dark leading-relaxed mb-7">{m.closing}</p>
      <a
        href={ctaHref}
        target={schedulingIsExternal ? '_blank' : undefined}
        rel={schedulingIsExternal ? 'noopener noreferrer' : undefined}
        class="inline-flex items-center gap-2 font-sans font-medium text-sm px-7 py-3.5 rounded-full bg-teal-dark text-cream hover:bg-teal transition-all duration-300"
      >
        <i class="ri-calendar-check-line" aria-hidden="true"></i>
        {m.ctaButton}
      </a>
    </div>
  </div>
</section>
