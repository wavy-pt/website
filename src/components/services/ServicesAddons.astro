---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).servicesPage.addons;

// Icones decorativos para cada add-on (substituem imagens externas do Readdy)
const addonIcons = [
  'ri-camera-3-line',
  'ri-search-eye-line',
  'ri-megaphone-line',
  'ri-map-pin-2-line',
  'ri-chat-smile-2-line',
];
---

<section class="bg-offwhite py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <!-- Header -->
      <div class="mb-10 md:mb-14">
        <p class="font-sans text-xs uppercase tracking-widest text-teal-dark mb-3">
          {i.label}
        </p>
        <div class="flex flex-col gap-3">
          <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-teal-dark leading-[1.15]">
            {i.title}
          </h2>
          <p class="font-sans text-base text-teal-dark/70 leading-relaxed max-w-xl">
            {i.subtitle}
          </p>
        </div>
      </div>

      <!-- Cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {i.items.map((addon, idx) => (
          <div class="bg-white rounded-2xl overflow-hidden border border-teal-dark/10 hover:border-teal/40 hover:-translate-y-1 transition-all duration-300 group">
            <!-- Header com gradient teal e ícone (substitui imagem) -->
            <div class="relative w-full h-40 overflow-hidden bg-gradient-to-br from-teal to-teal-dark flex items-center justify-center">
              <i class={`${addonIcons[idx] || addonIcons[0]} text-cream text-5xl opacity-90 group-hover:scale-110 transition-transform duration-500`} aria-hidden="true"></i>
            </div>
            <!-- Content -->
            <div class="p-5 md:p-6">
              <h3 class="font-serif text-lg md:text-xl font-medium text-teal-dark mb-2">
                {addon.name}
              </h3>
              <p class="font-sans text-sm text-muted leading-relaxed mb-4">
                {addon.desc}
              </p>
              <span class="font-sans text-xs uppercase tracking-wider text-teal font-medium">
                {addon.price}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
