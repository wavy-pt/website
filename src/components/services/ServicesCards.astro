---
import { t, getLocalizedPath } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).servicesPage;
const contactHref = getLocalizedPath('/contacto', lang);
---

<section class="bg-cream py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <!-- Section header -->
      <div class="text-center mb-10 md:mb-14">
        <p class="font-sans text-xs uppercase tracking-widest text-teal-dark mb-3">
          {i.hero.tag}
        </p>
        <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-teal-dark mb-4 leading-tight">
          {i.hero.headline}
        </h2>
        <p class="font-sans text-base text-muted leading-relaxed max-w-2xl mx-auto">
          {i.hero.subtitle}
        </p>
      </div>

      <!-- Cards grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 items-stretch max-w-5xl mx-auto">
        <!-- Start Card -->
        <div class="relative rounded-[24px] p-6 md:p-7 flex flex-col bg-white border border-teal-dark/10 transition-all duration-500 hover:-translate-y-1">
          <span class="inline-flex self-start font-sans text-[10px] uppercase tracking-wider px-3 py-1.5 rounded-full mb-5 bg-teal-dark/10 text-teal-dark/70">
            {i.start.tag}
          </span>
          <span class="font-serif text-2xl italic font-medium mb-1 text-teal">
            {i.start.scriptName}
          </span>
          <h3 class="font-serif text-xl md:text-2xl font-medium mb-2 text-teal-dark">
            {i.start.name}
          </h3>
          <p class="font-sans text-xs uppercase tracking-wider mb-3 text-muted">
            {i.start.tagline}
          </p>
          <p class="font-sans text-sm leading-relaxed mb-5 text-teal-dark/70">
            {i.start.desc}
          </p>
          <div class="space-y-2.5 mb-6 flex-1">
            {i.start.deliverables.map((item) => (
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 flex items-center justify-center flex-shrink-0 mt-0.5" aria-hidden="true">
                  <i class="ri-check-line text-teal font-bold"></i>
                </div>
                <span class="font-sans text-sm leading-relaxed text-teal-dark">
                  {item}
                </span>
              </div>
            ))}
          </div>
          <div class="flex items-baseline gap-2 mb-5">
            <span class="font-sans text-xs uppercase tracking-wider text-teal-dark/50">
              {i.start.priceLabel}
            </span>
            <span class="font-serif text-4xl md:text-5xl font-medium text-teal-dark">
              {i.start.price}
            </span>
          </div>
          <a
            href={contactHref}
            class="inline-flex items-center gap-2 font-sans text-sm font-medium group text-teal hover:text-teal-dark transition-colors py-3 -my-3"
          >
            {i.start.cta}
            <i class="ri-arrow-right-line transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
          </a>
        </div>

        <!-- Flow Card (with Presence/Growth toggle) -->
        <div
          id="flow-card"
          data-plan="presence"
          class="relative rounded-[24px] p-6 md:p-7 flex flex-col bg-white border border-teal-dark/10 transition-all duration-500 hover:-translate-y-1"
        >
          <span class="inline-flex self-start font-sans text-[10px] uppercase tracking-wider px-3 py-1.5 rounded-full mb-5 bg-teal-dark/10 text-teal-dark/70">
            {i.flow.tag}
          </span>
          <span class="font-serif text-2xl italic font-medium mb-1 text-teal">
            {i.flow.scriptName}
          </span>
          <h3 class="font-serif text-xl md:text-2xl font-medium mb-2 text-teal-dark">
            {i.flow.name}
          </h3>
          <p class="font-sans text-xs uppercase tracking-wider mb-3 text-muted" data-flow-tagline>
            {i.flow.presence.tagline}
          </p>
          <p class="font-sans text-sm leading-relaxed mb-5 text-teal-dark/70">
            {i.flow.desc}
          </p>

          <!-- Toggle Presence / Growth -->
          <div class="flex rounded-full bg-teal-dark/10 p-1 mb-5 self-start" role="tablist" aria-label={lang === 'en' ? 'Plan options' : 'Opções de plano'}>
            <button
              type="button"
              role="tab"
              data-flow-toggle="presence"
              data-tagline={i.flow.presence.tagline}
              data-price-label={i.flow.presence.priceLabel}
              data-price={i.flow.presence.price}
              data-price-period={i.flow.presence.pricePeriod}
              aria-selected="true"
              class="flow-toggle-btn flow-toggle-btn--active px-4 py-2 rounded-full font-sans text-xs font-medium transition-all duration-300 cursor-pointer"
            >
              {i.flow.presence.label}
            </button>
            <button
              type="button"
              role="tab"
              data-flow-toggle="growth"
              data-tagline={i.flow.growth.tagline}
              data-price-label={i.flow.growth.priceLabel}
              data-price={i.flow.growth.price}
              data-price-period={i.flow.growth.pricePeriod}
              aria-selected="false"
              class="flow-toggle-btn px-4 py-2 rounded-full font-sans text-xs font-medium transition-all duration-300 cursor-pointer"
            >
              {i.flow.growth.label}
            </button>
          </div>

          <!-- Presence deliverables -->
          <div class="space-y-2.5 mb-6 flex-1" data-flow-deliverables="presence">
            {i.flow.presence.deliverables.map((item) => (
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 flex items-center justify-center flex-shrink-0 mt-0.5" aria-hidden="true">
                  <i class="ri-check-line text-teal font-bold"></i>
                </div>
                <span class="font-sans text-sm leading-relaxed text-teal-dark">
                  {item}
                </span>
              </div>
            ))}
          </div>

          <!-- Growth deliverables (hidden by default) -->
          <div class="space-y-2.5 mb-6 flex-1 hidden" data-flow-deliverables="growth">
            {i.flow.growth.deliverables.map((item) => (
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 flex items-center justify-center flex-shrink-0 mt-0.5" aria-hidden="true">
                  <i class="ri-check-line text-teal font-bold"></i>
                </div>
                <span class="font-sans text-sm leading-relaxed text-teal-dark">
                  {item}
                </span>
              </div>
            ))}
          </div>

          <!-- Price (changes with toggle) -->
          <div class="flex items-baseline gap-2 mb-5" data-flow-price>
            <span class="font-sans text-xs uppercase tracking-wider text-teal-dark/50" data-flow-price-label>
              {i.flow.presence.priceLabel}
            </span>
            <span class="font-serif text-4xl md:text-5xl font-medium text-teal-dark" data-flow-price-value>
              {i.flow.presence.price}
            </span>
            <span class="font-sans text-sm text-teal-dark/50" data-flow-price-period>
              {i.flow.presence.pricePeriod}
            </span>
          </div>

          <a
            href={contactHref}
            class="inline-flex items-center gap-2 font-sans text-sm font-medium group text-teal hover:text-teal-dark transition-colors py-3 -my-3"
          >
            {i.flow.cta}
            <i class="ri-arrow-right-line transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .flow-toggle-btn {
    color: rgba(28, 60, 60, 0.5);
  }
  .flow-toggle-btn:hover {
    color: rgb(28, 60, 60);
  }
  .flow-toggle-btn--active {
    background-color: white;
    color: #1C3C3C;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }
</style>

<script is:inline>
  // Toggle Presence / Growth no card Flow.
  // Os valores (tagline, preço, etc.) vêm dos data-* attributes nos
  // botões toggle, já com a língua certa renderizada pelo Astro.
  (function () {
    const card = document.getElementById('flow-card');
    if (!card) return;

    const toggles = card.querySelectorAll('[data-flow-toggle]');
    const deliverableBlocks = card.querySelectorAll('[data-flow-deliverables]');
    const taglineEl = card.querySelector('[data-flow-tagline]');
    const priceLabelEl = card.querySelector('[data-flow-price-label]');
    const priceValueEl = card.querySelector('[data-flow-price-value]');
    const pricePeriodEl = card.querySelector('[data-flow-price-period]');

    function activatePlan(plan) {
      card.setAttribute('data-plan', plan);

      toggles.forEach(function (btn) {
        const isActive = btn.getAttribute('data-flow-toggle') === plan;
        btn.classList.toggle('flow-toggle-btn--active', isActive);
        btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      deliverableBlocks.forEach(function (block) {
        const isActive = block.getAttribute('data-flow-deliverables') === plan;
        block.classList.toggle('hidden', !isActive);
      });

      const activeBtn = card.querySelector('[data-flow-toggle="' + plan + '"]');
      if (!activeBtn) return;

      if (taglineEl) taglineEl.textContent = activeBtn.getAttribute('data-tagline') || '';
      if (priceLabelEl) priceLabelEl.textContent = activeBtn.getAttribute('data-price-label') || '';
      if (priceValueEl) priceValueEl.textContent = activeBtn.getAttribute('data-price') || '';
      if (pricePeriodEl) pricePeriodEl.textContent = activeBtn.getAttribute('data-price-period') || '';
    }

    toggles.forEach(function (btn) {
      btn.addEventListener('click', function () {
        const plan = btn.getAttribute('data-flow-toggle');
        if (plan) activatePlan(plan);
      });
    });
  })();
</script>
