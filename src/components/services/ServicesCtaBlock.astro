---
import { Image } from 'astro:assets';
import { t, getLocalizedPath } from '../../i18n';
import type { Lang } from '../../i18n';
import bastidoresImage from '../../assets/wavy-bastidores.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).servicesPage.cta;
const contactHref = getLocalizedPath('/contacto', lang);
---

<section class="bg-offwhite py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 items-stretch">
        <!-- Left — Big explorer card with image -->
        <div class="relative rounded-[28px] overflow-hidden min-h-[380px] lg:min-h-0">
          <Image
            src={bastidoresImage}
            alt="Workspace criativo — Wavy"
            class="absolute inset-0 w-full h-full object-cover object-top"
            loading="lazy"
            widths={[640, 960, 1280]}
            sizes="(min-width: 1024px) 50vw, 100vw"
            quality={85}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-teal-dark/95 via-teal-dark/80 to-teal-dark/40" aria-hidden="true"></div>
          <div class="relative z-10 p-8 md:p-10 flex flex-col justify-end h-full min-h-[380px]">
            <h2 class="font-serif text-[2.25rem] sm:text-4xl md:text-5xl lg:text-6xl font-medium text-cream leading-[1.1] mb-4">
              {i.explorerTitle}
            </h2>
            <p class="font-sans text-base text-cream/85 leading-relaxed max-w-md mb-2">
              {i.explorerSubtitle}
            </p>
            <p class="font-sans text-sm text-teal-light mb-6">
              {i.explorerDuration}
            </p>
            <a
              href={contactHref}
              class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm md:text-base px-7 py-3.5 md:px-8 md:py-4 rounded-full bg-cream text-teal-dark hover:bg-offwhite transition-all duration-300 whitespace-nowrap w-full sm:w-auto self-start"
            >
              {i.explorerCta}
              <i class="ri-arrow-right-up-line" aria-hidden="true"></i>
            </a>
          </div>
        </div>

        <!-- Right — CTA actions -->
        <div class="flex flex-col gap-5">
          <!-- Main CTA card (teal) -->
          <div class="relative rounded-[28px] overflow-hidden flex-1 min-h-[200px] bg-teal">
            <Image
              src={bastidoresImage}
              alt=""
              class="absolute inset-0 w-full h-full object-cover object-top opacity-50"
              loading="lazy"
              widths={[480, 640, 960]}
              sizes="(min-width: 1024px) 50vw, 100vw"
              quality={75}
            />
            <div class="absolute inset-0 bg-gradient-to-r from-teal/95 via-teal/85 to-teal/70" aria-hidden="true"></div>
            <div class="relative z-10 p-6 md:p-8 flex flex-col justify-center h-full">
              <h3 class="font-serif text-2xl sm:text-3xl md:text-4xl font-medium text-cream leading-[1.1] mb-3">
                {i.ctaCardTitle}
              </h3>
              <p class="font-sans text-base text-cream/85 mb-6">
                {i.ctaCardDesc}
              </p>
              <a
                href={contactHref}
                class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm md:text-base px-7 py-3.5 md:px-8 md:py-4 rounded-full bg-cream text-teal-dark hover:bg-offwhite transition-all duration-300 whitespace-nowrap w-full sm:w-auto self-start"
              >
                {i.ctaCardButton}
                <i class="ri-calendar-check-line" aria-hidden="true"></i>
              </a>
            </div>
          </div>

          <!-- Secondary action row -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <!-- Social card -->
            <div class="bg-cream rounded-[28px] p-5 md:p-6 flex flex-col justify-center">
              <p class="font-sans text-sm font-medium text-teal-dark mb-4">
                {i.socialLabel}
              </p>
              <div class="flex items-center gap-3">
                <a
                  href="https://instagram.com/wavy.digital.pt"
                  target="_blank"
                  rel="nofollow noreferrer"
                  aria-label={lang === 'en' ? 'Wavy on Instagram' : 'Instagram da Wavy'}
                  class="w-11 h-11 flex items-center justify-center rounded-full bg-teal/10 text-teal hover:bg-teal hover:text-cream transition-all duration-200"
                >
                  <i class="ri-instagram-line text-lg" aria-hidden="true"></i>
                </a>
                <a
                  href="https://facebook.com/wavy.digital.pt"
                  target="_blank"
                  rel="nofollow noreferrer"
                  aria-label={lang === 'en' ? 'Wavy on Facebook' : 'Facebook da Wavy'}
                  class="w-11 h-11 flex items-center justify-center rounded-full bg-teal/10 text-teal hover:bg-teal hover:text-cream transition-all duration-200"
                >
                  <i class="ri-facebook-line text-lg" aria-hidden="true"></i>
                </a>
              </div>
            </div>

            <!-- Email card -->
            <a
              href={`mailto:${i.emailAddress}`}
              class="bg-cream rounded-[28px] p-5 md:p-6 flex items-center gap-4 hover:bg-warm transition-all duration-300 group"
            >
              <div class="w-12 h-12 flex items-center justify-center rounded-full bg-teal/10 flex-shrink-0">
                <i class="ri-mail-send-line text-teal text-xl" aria-hidden="true"></i>
              </div>
              <div>
                <p class="font-sans text-sm font-medium text-teal-dark group-hover:text-teal transition-colors">
                  {i.emailLabel}
                </p>
                <p class="font-sans text-xs text-muted mt-0.5">{i.emailAddress}</p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
