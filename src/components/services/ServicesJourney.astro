---
import { t, getLocalizedPath } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const j = t(lang).servicesPage.journey;
const contactHref = getLocalizedPath('/contacto', lang);
---

<section class="bg-cream py-16 md:py-24 relative">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <!-- Section header -->
    <div class="scroll-reveal text-center mb-14 md:mb-20 max-w-3xl mx-auto">
      <p class="font-sans text-xs uppercase tracking-widest text-teal-dark mb-3">
        {j.label}
      </p>
      <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-teal-dark mb-4 leading-tight">
        {j.title}
      </h2>
      <p class="font-sans text-base md:text-lg text-muted leading-relaxed">
        {j.subtitle}
      </p>
    </div>

    <!-- Jornada: 3 services em zigzag -->
    <div class="flex flex-col gap-14 md:gap-20">
      {j.services.map((s, idx) => {
        const isEven = idx % 2 === 0;
        const isFirst = idx === 0;
        const isLast = idx === j.services.length - 1;

        return (
          <div class="scroll-reveal relative">
            {/* Connector vertical entre cards (subtil sobre cream) */}
            {!isLast && (
              <div class="absolute left-1/2 -bottom-14 md:-bottom-20 -translate-x-1/2 z-0 flex flex-col items-center gap-1 pointer-events-none" aria-hidden="true">
                <div class="w-px h-14 md:h-20 bg-teal-dark/15"></div>
              </div>
            )}

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-stretch bg-white rounded-[32px] p-6 sm:p-8 md:p-10 lg:p-12 border border-teal-dark/8 shadow-[0_4px_24px_-8px_rgba(28,60,60,0.08)]">
              {/* Image / illustration (col-span-6 — maior que antes) */}
              <div class:list={[
                'lg:col-span-6 relative',
                isEven ? 'lg:order-1' : 'lg:order-2',
              ]}>
                <div class="relative aspect-[5/4] rounded-[24px] overflow-hidden bg-gradient-to-br from-teal to-teal-dark flex items-center justify-center">
                  {/* Decorative circles */}
                  <div class="absolute -top-16 -left-16 w-48 h-48 rounded-full bg-cream/5" aria-hidden="true"></div>
                  <div class="absolute -bottom-20 -right-20 w-60 h-60 rounded-full bg-cream/5" aria-hidden="true"></div>
                  <div class="absolute top-8 right-8 w-20 h-20 rounded-full border border-cream/15" aria-hidden="true"></div>

                  {/* Grande número decorativo */}
                  <span class="absolute top-4 right-6 md:top-8 md:right-10 font-serif text-[6rem] md:text-[9rem] font-medium text-cream/10 leading-none select-none" aria-hidden="true">
                    {s.number}
                  </span>

                  {/* Ícone principal */}
                  <div class="relative z-10">
                    <i class:list={[s.icon, 'text-cream text-[7rem] md:text-[10rem] opacity-95']} aria-hidden="true"></i>
                  </div>

                  {/* Number badge (cream pill no canto) */}
                  <div class="absolute top-4 left-4 md:top-6 md:left-6 w-12 h-12 md:w-14 md:h-14 rounded-full bg-cream flex items-center justify-center shadow-lg z-10">
                    <span class="font-serif text-lg md:text-xl font-medium text-teal-dark">{s.number}</span>
                  </div>

                  {/* Badge "Obrigatório" no Raio-X */}
                  {isFirst && (
                    <div class="absolute top-4 right-4 md:top-6 md:right-6 z-10">
                      <span class="inline-flex font-sans text-[10px] sm:text-xs font-semibold uppercase tracking-widest text-teal-dark bg-cream px-3 py-1.5 rounded-full shadow-md">
                        {j.obligatoryBadge}
                      </span>
                    </div>
                  )}
                </div>
              </div>

              {/* Content (col-span-6) */}
              <div class:list={[
                'lg:col-span-6 flex flex-col justify-center',
                isEven ? 'lg:order-2' : 'lg:order-1',
              ]}>
                {/* Tag (PONTO DE PARTIDA OBRIGATÓRIO / etc.) */}
                <p class:list={[
                  'font-sans text-[11px] sm:text-xs uppercase tracking-[0.2em] font-medium mb-3',
                  s.tagHighlight ? 'text-teal' : 'text-muted',
                ]}>
                  {s.tag}
                </p>

                {/* Script name (italic) */}
                <p class="font-serif text-xl sm:text-2xl italic font-medium text-teal mb-1">
                  {s.scriptName}
                </p>

                {/* Name (large) */}
                <h3 class="font-serif text-3xl sm:text-4xl md:text-5xl font-medium text-teal-dark mb-3 leading-tight">
                  {s.name}
                </h3>

                {/* Tagline */}
                <p class="font-sans text-sm uppercase tracking-wider text-muted mb-5">
                  {s.tagline}
                </p>

                {/* Description */}
                <p class="font-sans text-base text-teal-dark/80 leading-relaxed mb-6 max-w-xl">
                  {s.desc}
                </p>

                {/* Deliverables */}
                <div class="space-y-2.5 mb-7">
                  {s.deliverables.map((item) => (
                    <div class="flex items-start gap-3">
                      <div class="w-5 h-5 flex items-center justify-center flex-shrink-0 mt-0.5" aria-hidden="true">
                        <i class="ri-check-line text-teal font-bold"></i>
                      </div>
                      <span class="font-sans text-sm md:text-base leading-relaxed text-teal-dark">
                        {item}
                      </span>
                    </div>
                  ))}
                </div>

                {/* Price + CTA */}
                <div class="border-t border-teal-dark/10 pt-5 flex flex-col sm:flex-row sm:items-end sm:justify-between gap-5">
                  <div>
                    <div class="flex items-baseline gap-2 flex-wrap">
                      <span class="font-sans text-xs uppercase tracking-wider text-teal-dark/60">
                        {s.priceLabel}
                      </span>
                      <span class="font-serif text-4xl sm:text-5xl md:text-6xl font-medium text-teal-dark leading-none">
                        {s.price}
                      </span>
                      {s.pricePeriod && (
                        <span class="font-sans text-base text-teal-dark/60">
                          {s.pricePeriod}
                        </span>
                      )}
                    </div>
                    {s.priceNote && (
                      <p class="font-sans text-xs mt-2 text-muted max-w-xs">
                        {s.priceNote}
                      </p>
                    )}
                  </div>
                  <a
                    href={contactHref}
                    class="inline-flex items-center justify-center gap-2 font-sans text-sm font-medium px-6 py-3 rounded-full bg-teal text-cream hover:bg-teal-dark transition-all duration-300 whitespace-nowrap shrink-0 group"
                  >
                    {s.cta}
                    <i class="ri-arrow-right-line transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
