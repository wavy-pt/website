---
/**
 * Quiz de diagnóstico digital (full-width) na página /servicos.
 *
 * 3 estados num só card (alternados por `data-state`):
 *   - intro    → título "Ainda a explorar?" + botão "Saber onde estou"
 *   - quiz     → uma pergunta de cada vez, barra de progresso, opções clicáveis
 *   - result   → nível ("A construir"/"A afinar"/"A crescer") + cor + recomendação
 *
 * O conteúdo (perguntas, scores, resultados) vem da i18n (servicesPage.quiz).
 * O scoring é feito em JS lendo os `data-score` das opções; o tier final é
 * escolhido por percentagem do score máximo possível.
 */
import { t, getLocalizedPath } from '../../i18n';
import type { Lang } from '../../i18n';
import { contactHref } from '../../lib/env';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const sp = t(lang).servicesPage;
const c = sp.cta; // strings de intro reutilizadas (explorerTitle, etc.)
const q = sp.quiz;
const ctaHref = contactHref(getLocalizedPath('/contacto', lang));

// Score máximo possível (soma do maior score de cada pergunta) → usado no JS
const maxScore = q.questions.reduce(
  (sum, question) => sum + Math.max(...question.options.map((o) => o.score)),
  0
);
---

<div
  id="services-quiz"
  data-state="intro"
  data-max-score={maxScore}
  class="services-quiz relative overflow-hidden rounded-[32px] bg-cream border border-teal-dark/10 shadow-[0_20px_60px_-24px_rgba(28,60,60,0.20)]"
>
  <!-- Decorações subtis -->
  <div class="absolute -top-24 -right-24 w-80 h-80 rounded-full bg-teal/5 blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -bottom-32 -left-24 w-96 h-96 rounded-full bg-teal-dark/5 blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative p-8 sm:p-10 md:p-14 min-h-[380px] flex flex-col justify-center">
    <!-- ============ INTRO ============ -->
    <div class="quiz-panel quiz-intro">
      <div class="flex items-center justify-between gap-8">
        <div class="max-w-2xl">
          <span class="inline-flex items-center gap-2 font-sans text-xs font-medium uppercase tracking-widest text-teal-dark bg-teal/10 px-4 py-2 rounded-full mb-6">
            <i class="ri-compass-3-line text-sm" aria-hidden="true"></i>
            {c.explorerDuration}
          </span>
          <h2 class="font-serif text-[2.25rem] sm:text-4xl md:text-5xl lg:text-6xl font-medium text-teal-dark leading-[1.05] mb-4">
            {c.explorerTitle}
          </h2>
          <p class="font-sans text-base md:text-lg text-muted leading-relaxed mb-8 max-w-lg">
            {c.explorerSubtitle}
          </p>
          <button
            type="button"
            data-quiz-start
            class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm md:text-base px-7 py-3.5 md:px-9 md:py-4 rounded-full bg-teal-dark text-cream hover:bg-teal transition-all duration-300 whitespace-nowrap group"
          >
            {c.explorerCta}
            <i class="ri-arrow-right-line transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
          </button>
        </div>

        <!-- Ícone decorativo de questionário (desktop) -->
        <div class="hidden lg:flex flex-shrink-0 items-center justify-center pr-4 xl:pr-8" aria-hidden="true">
          <div class="w-40 h-40 xl:w-48 xl:h-48 rounded-full bg-teal/10 flex items-center justify-center">
            <i class="ri-survey-line text-teal text-[5rem] xl:text-[6rem]"></i>
          </div>
        </div>
      </div>
    </div>

    <!-- ============ QUIZ ============ -->
    <div class="quiz-panel quiz-questions max-w-2xl w-full mx-auto">
      <!-- Progresso -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-3">
          <span
            data-quiz-progress
            data-progress-template={q.progressTemplate}
            class="font-sans text-xs uppercase tracking-widest text-teal-dark/60"
          ></span>
          <button
            type="button"
            data-quiz-restart
            class="font-sans text-xs text-teal-dark/50 hover:text-teal-dark transition-colors inline-flex items-center gap-1"
          >
            <i class="ri-restart-line text-sm" aria-hidden="true"></i>
            {q.restartButton}
          </button>
        </div>
        <div class="h-1.5 rounded-full bg-teal-dark/10 overflow-hidden">
          <div
            data-quiz-progress-bar
            class="h-full rounded-full bg-gradient-to-r from-teal to-teal-dark transition-[width] duration-500 ease-out"
            style="width: 0%"
          ></div>
        </div>
      </div>

      <!-- Perguntas (uma visível de cada vez) -->
      {q.questions.map((question, idx) => (
        <div class="quiz-question" data-q-index={idx} hidden={idx !== 0}>
          <h3
            tabindex="-1"
            class="font-serif text-2xl sm:text-3xl font-medium text-teal-dark leading-tight mb-6 outline-none"
          >
            {question.question}
          </h3>
          <div class="flex flex-col gap-3">
            {question.options.map((opt) => (
              <button
                type="button"
                data-score={opt.score}
                class="quiz-option group flex items-center justify-between gap-4 w-full text-left px-5 py-4 rounded-2xl border border-teal-dark/15 bg-white hover:border-teal hover:bg-teal/5 focus-visible:ring-2 focus-visible:ring-teal focus-visible:ring-offset-2 transition-all duration-200 cursor-pointer"
              >
                <span class="font-sans text-sm sm:text-base text-teal-dark">
                  {opt.label}
                </span>
                <span class="w-7 h-7 flex-shrink-0 rounded-full border border-teal-dark/20 flex items-center justify-center text-teal-dark/40 group-hover:border-teal group-hover:bg-teal group-hover:text-cream transition-all duration-200">
                  <i class="ri-arrow-right-line text-sm" aria-hidden="true"></i>
                </span>
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- ============ RESULT ============ -->
    <div class="quiz-panel quiz-result max-w-2xl w-full mx-auto" data-tier="">
      <p class="font-sans text-xs uppercase tracking-widest text-teal-dark/60 mb-6">
        {q.resultLabel}
      </p>

      {q.results.map((r, ridx) => (
        <div class="quiz-result-tier" data-result-tier={r.tier}>
          <!-- Indicador de 3 segmentos (preenche conforme o nível) -->
          <div class="flex items-center gap-2 mb-5" aria-hidden="true">
            {[0, 1, 2].map((s) => (
              <span
                class:list={[
                  'h-2 w-14 rounded-full transition-colors',
                  s <= ridx ? `quiz-seg-${r.tier}` : 'bg-teal-dark/10',
                ]}
              ></span>
            ))}
          </div>

          <h3
            tabindex="-1"
            class="quiz-level font-serif text-4xl sm:text-5xl font-medium leading-none mb-4 outline-none"
          >
            {r.level}
          </h3>
          <p class="font-serif text-xl sm:text-2xl italic font-medium text-teal-dark mb-4">
            {r.headline}
          </p>
          <p class="font-sans text-base text-teal-dark/75 leading-relaxed max-w-xl">
            {r.recommendation}
          </p>
        </div>
      ))}

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 mt-8">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm md:text-base px-7 py-3.5 md:px-8 md:py-4 rounded-full bg-teal-dark text-cream hover:bg-teal transition-all duration-300 whitespace-nowrap group"
        >
          {q.ctaButton}
          <i class="ri-arrow-right-up-line transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" aria-hidden="true"></i>
        </a>
        <button
          type="button"
          data-quiz-restart
          class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm md:text-base px-7 py-3.5 md:px-8 md:py-4 rounded-full border border-teal-dark/15 text-teal-dark hover:border-teal-dark hover:bg-teal-dark/5 transition-all duration-300 whitespace-nowrap"
        >
          <i class="ri-restart-line" aria-hidden="true"></i>
          {q.restartButton}
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Alternância de estados */
  .services-quiz .quiz-panel { display: none; }
  .services-quiz[data-state="intro"] .quiz-intro { display: block; animation: quizFade 450ms ease; }
  .services-quiz[data-state="quiz"] .quiz-questions { display: block; }
  .services-quiz[data-state="result"] .quiz-result { display: block; animation: quizFade 450ms ease; }

  /* Pergunta visível faz fade-in suave */
  .quiz-question:not([hidden]) { animation: quizFade 400ms ease; }

  /* Resultado: mostrar só o tier ativo */
  .quiz-result-tier { display: none; }
  .quiz-result[data-tier="low"] .quiz-result-tier[data-result-tier="low"],
  .quiz-result[data-tier="mid"] .quiz-result-tier[data-result-tier="mid"],
  .quiz-result[data-tier="high"] .quiz-result-tier[data-result-tier="high"] { display: block; }

  /* Cor do nível por tier (todas visíveis sobre o card cream) */
  .quiz-result-tier[data-result-tier="low"] .quiz-level { color: var(--color-teal-dark); }
  .quiz-result-tier[data-result-tier="mid"] .quiz-level { color: var(--color-teal); }
  .quiz-result-tier[data-result-tier="high"] .quiz-level { color: var(--color-teal-light); }

  /* Segmentos preenchidos por tier */
  .quiz-seg-low { background-color: var(--color-teal-dark); }
  .quiz-seg-mid { background-color: var(--color-teal); }
  .quiz-seg-high { background-color: var(--color-teal-light); }

  @keyframes quizFade {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .services-quiz .quiz-panel,
    .quiz-question:not([hidden]) { animation: none; }
    .services-quiz [data-quiz-progress-bar] { transition: none; }
  }
</style>

<script>
  function initServicesQuiz() {
    const quiz = document.getElementById('services-quiz');
    if (!quiz || quiz.dataset.initialized === 'true') return;
    quiz.dataset.initialized = 'true';

    const maxScore = Number(quiz.dataset.maxScore) || 1;
    const startBtn = quiz.querySelector<HTMLButtonElement>('[data-quiz-start]');
    const questions = Array.from(quiz.querySelectorAll<HTMLElement>('.quiz-question'));
    const total = questions.length;
    const progressText = quiz.querySelector<HTMLElement>('[data-quiz-progress]');
    const progressBar = quiz.querySelector<HTMLElement>('[data-quiz-progress-bar]');
    const resultPanel = quiz.querySelector<HTMLElement>('.quiz-result');
    const restartBtns = Array.from(quiz.querySelectorAll<HTMLButtonElement>('[data-quiz-restart]'));
    const template = progressText?.dataset.progressTemplate || 'Pergunta {current} de {total}';

    let current = 0;
    let score = 0;

    const setState = (state: string) => {
      quiz.dataset.state = state;
    };

    const showQuestion = (idx: number, focusOpts?: FocusOptions) => {
      questions.forEach((el, i) => {
        el.hidden = i !== idx;
      });
      if (progressText) {
        progressText.textContent = template
          .replace('{current}', String(idx + 1))
          .replace('{total}', String(total));
      }
      if (progressBar) {
        progressBar.style.width = `${((idx + 1) / total) * 100}%`;
      }
      // Foco no enunciado para leitores de ecrã
      (questions[idx].querySelector('h3') as HTMLElement | null)?.focus(focusOpts);
    };

    const startQuiz = (focusOpts?: FocusOptions) => {
      current = 0;
      score = 0;
      setState('quiz');
      showQuestion(0, focusOpts);
    };

    const showResult = () => {
      const pct = (score / maxScore) * 100;
      const tier = pct <= 35 ? 'low' : pct <= 70 ? 'mid' : 'high';
      if (resultPanel) resultPanel.dataset.tier = tier;
      setState('result');
      const heading = resultPanel?.querySelector<HTMLElement>(
        `[data-result-tier="${tier}"] .quiz-level`
      );
      heading?.focus();
    };

    const answer = (optScore: number) => {
      score += optScore;
      if (current < total - 1) {
        current += 1;
        showQuestion(current);
      } else {
        showResult();
      }
    };

    startBtn?.addEventListener('click', () => startQuiz());

    questions.forEach((el) => {
      el.querySelectorAll<HTMLButtonElement>('[data-score]').forEach((btn) => {
        btn.addEventListener('click', () => answer(Number(btn.dataset.score)));
      });
    });

    restartBtns.forEach((b) => b.addEventListener('click', () => startQuiz()));

    // Auto-abrir o quiz (já na 1ª pergunta) quando se chega via #teste —
    // vindo dos botões "teste rápido" espalhados pelo site.
    if (window.location.hash === '#teste') {
      startQuiz({ preventScroll: true });
      // Garante que o quiz fica visível (cobre também as view transitions do Astro).
      requestAnimationFrame(() => {
        document.getElementById('teste')?.scrollIntoView({ block: 'start' });
      });
    }
  }

  document.addEventListener('astro:page-load', initServicesQuiz);
  if (document.readyState !== 'loading') {
    initServicesQuiz();
  } else {
    document.addEventListener('DOMContentLoaded', initServicesQuiz);
  }
</script>
