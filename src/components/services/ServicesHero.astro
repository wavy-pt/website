---
import { Image } from 'astro:assets';
import { t } from '../../i18n';
import type { Lang } from '../../i18n';
import heroImage from '../../assets/wavy-servicos.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const sp = i.servicesPage;
---

<section class="relative min-h-[88vh] md:min-h-screen flex items-center pt-28 md:pt-32 pb-36 md:pb-44 overflow-hidden">
  <!-- Background image (workspace criativo, mesma do Readdy original) -->
  <Image
    src={heroImage}
    alt="Workspace criativo, laptop e headphones na mesa"
    class="absolute inset-0 w-full h-full object-cover object-top"
    loading="eager"
    fetchpriority="high"
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
    quality={85}
  />

  <!-- Top overlay: escuro para legibilidade do texto da nav + headline -->
  <div class="absolute inset-x-0 top-0 h-1/2 bg-gradient-to-b from-teal-dark/55 via-teal-dark/25 to-transparent" aria-hidden="true"></div>

  <!-- Bottom overlay: feathering longo da imagem para cream (transição suave para a secção de serviços) -->
  <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-b from-transparent via-cream/30 via-50% to-cream" aria-hidden="true"></div>

  <!-- Content (centrado verticalmente) -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 w-full">
    <div class="scroll-reveal max-w-3xl">
      <span class="inline-flex font-sans text-xs sm:text-sm font-medium uppercase tracking-[0.2em] text-cream bg-cream/15 backdrop-blur-sm border border-cream/25 px-4 py-2 rounded-full mb-5">
        {sp.hero.tag}
      </span>
      <h1 class="font-serif text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-medium text-white mb-6 leading-[1.1] drop-shadow-sm">
        {sp.hero.headline}
      </h1>
      <p class="font-sans text-base md:text-lg text-white/85 leading-relaxed max-w-xl">
        {sp.hero.subtitle}
      </p>
    </div>
  </div>

  <!-- Scroll indicator (fundo do hero, centrado, em zona já cream pelo gradient) -->
  <div class="absolute bottom-8 md:bottom-12 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-2 pointer-events-none">
    <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-teal-dark mb-1">
      {i.hero.scroll}
    </p>
    <div class="w-9 h-9 rounded-full border border-teal-dark/40 flex items-center justify-center animate-scroll-hint bg-cream/60 backdrop-blur-sm">
      <i class="ri-arrow-down-line text-teal-dark text-sm" aria-hidden="true"></i>
    </div>
  </div>
</section>
