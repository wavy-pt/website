---
import { Image } from 'astro:assets';
import { t } from '../../i18n';
import type { Lang } from '../../i18n';
import heroImage from '../../assets/wavy-bastidores.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).servicesPage;
---

<section class="relative min-h-[70vh] md:min-h-[80vh] flex items-end pb-16 md:pb-24 overflow-hidden">
  <!-- Background image -->
  <Image
    src={heroImage}
    alt="Workspace criativo — Wavy"
    class="absolute inset-0 w-full h-full object-cover object-top"
    loading="eager"
    fetchpriority="high"
    widths={[640, 960, 1280, 1920]}
    sizes="100vw"
    quality={85}
  />

  <!-- Soft gradient overlay — fades to cream at bottom for smooth transition -->
  <div class="absolute inset-0 bg-gradient-to-b from-teal-dark/50 via-teal-dark/40 to-cream" aria-hidden="true"></div>

  <!-- Additional soft top overlay for text readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-transparent via-teal-dark/20 to-teal-dark/40" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 w-full">
    <div class="scroll-reveal max-w-3xl">
      <p class="font-sans text-xs uppercase tracking-widest text-teal-light mb-4">
        {i.hero.tag}
      </p>
      <h1 class="font-serif text-[2.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-medium text-white mb-6 leading-[1.1] drop-shadow-sm">
        {i.hero.headline}
      </h1>
      <p class="font-sans text-base md:text-lg text-white/85 leading-relaxed max-w-xl">
        {i.hero.subtitle}
      </p>
    </div>
  </div>
</section>
