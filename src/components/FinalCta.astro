---
import { t, getLocalizedPath } from '../i18n';
import type { Lang } from '../i18n';
import { contactHref, schedulingHref, schedulingIsExternal } from '../lib/env';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const ctaHref = contactHref(getLocalizedPath('/contacto', lang));
const schedulingUrl = schedulingHref(getLocalizedPath('/contacto', lang));
// Teste rápido → /servicos (onde vive o quiz) provisoriamente.
const diagnosisUrl = `${getLocalizedPath('/servicos', lang)}#teste`;
---

<section class="bg-offwhite py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <!-- Section label -->
    <div class="scroll-reveal text-center mb-10 md:mb-14">
      <p class="font-serif italic text-teal text-base md:text-lg mb-3">
        {i.finalCta.label}
      </p>
      <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-teal-dark leading-[1.15] md:leading-tight max-w-2xl mx-auto">
        {lang === 'en'
          ? 'Shall we find out if Wavy is the right partner for you?'
          : 'Vamos descobrir se a Wavy é o parceiro certo para ti?'}
      </h2>
      <p class="font-sans text-base text-muted leading-relaxed max-w-xl mx-auto mt-4">
        {lang === 'en'
          ? "Choose the path that feels right. There's no wrong answer — just different roads to the same destination."
          : 'Escolhe o caminho mais confortável. Não há resposta errada — só direções diferentes para o mesmo destino.'}
      </p>
    </div>

    <!-- Split block -->
    <div class="scroll-reveal grid grid-cols-1 lg:grid-cols-2 rounded-[32px] overflow-hidden shadow-xl">
      <!-- LEFT side — cream (secondary path) -->
      <div class="bg-cream p-8 sm:p-10 md:p-14 flex flex-col relative overflow-hidden min-h-[380px] md:min-h-[420px]">
        <!-- Decorative icon -->
        <div class="absolute top-6 right-6 md:top-10 md:right-10">
          <div class="w-11 h-11 md:w-14 md:h-14 rounded-full bg-teal/10 flex items-center justify-center">
            <i class="ri-compass-discover-line text-teal text-lg md:text-2xl"></i>
          </div>
        </div>

        <!-- Decorative shape -->
        <span class="absolute bottom-4 right-6 md:bottom-6 md:right-8 font-serif text-[140px] sm:text-[170px] md:text-[200px] font-medium text-teal/15 leading-none select-none pointer-events-none">
          ?
        </span>

        <div class="relative flex flex-col flex-1 max-w-md">
          <p class="font-sans text-[11px] uppercase tracking-widest text-teal-dark/60 mb-4">
            {lang === 'en' ? 'Still exploring' : 'Ainda a explorar'}
          </p>
          <h3 class="font-serif text-2xl sm:text-3xl md:text-4xl font-medium text-teal-dark mb-5 leading-tight">
            {lang === 'en' ? 'Take the 2-minute test.' : 'Faz o teste em 2 minutos.'}
          </h3>
          <p class="font-sans text-base text-teal-dark/70 leading-relaxed mb-8">
            {lang === 'en'
              ? "Five questions, one personalised answer. In 2 minutes you'll know whether your digital presence needs real intervention or just small adjustments."
              : 'Cinco perguntas, uma resposta personalizada. Em 2 minutos ficas a saber se a tua presença digital precisa de uma intervenção real ou apenas de pequenos ajustes.'}
          </p>

          <div class="mt-auto">
            <a
              href={diagnosisUrl}
              class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full bg-teal-dark text-cream font-sans font-medium text-sm hover:bg-teal transition-all duration-300 group"
            >
              {i.finalCta.secondaryCta}
              <i class="ri-arrow-right-line transition-transform duration-200 group-hover:translate-x-1"></i>
            </a>
            <p class="font-serif italic text-xs text-teal-dark/75 mt-4">
              {lang === 'en' ? '2 minutes · no strings attached · answer at the end' : '2 minutos · sem compromisso · resposta no fim'}
            </p>
          </div>
        </div>
      </div>

      <!-- RIGHT side — teal (primary path) -->
      <div class="bg-teal p-8 sm:p-10 md:p-14 flex flex-col relative overflow-hidden min-h-[380px] md:min-h-[420px]">
        <!-- Decorative icon -->
        <div class="absolute top-6 right-6 md:top-10 md:right-10">
          <div class="w-11 h-11 md:w-14 md:h-14 rounded-full bg-cream/15 flex items-center justify-center">
            <i class="ri-calendar-check-line text-cream text-lg md:text-2xl"></i>
          </div>
        </div>

        <!-- Decorative big mark -->
        <span class="absolute bottom-6 right-6 md:bottom-10 md:right-10 font-sans text-[100px] sm:text-[130px] md:text-[160px] font-light text-cream/30 leading-none select-none pointer-events-none">
          →
        </span>

        <div class="relative flex flex-col flex-1 max-w-md">
          <p class="font-sans text-[11px] uppercase tracking-widest text-cream/60 mb-4">
            {lang === 'en' ? "Ready to talk" : 'Pronto para conversar'}
          </p>
          <h3 class="font-serif text-2xl sm:text-3xl md:text-4xl font-medium text-cream mb-5 leading-tight">
            {lang === 'en' ? 'Book a 30-minute call.' : 'Marca uma conversa de 30 minutos.'}
          </h3>
          <p class="font-sans text-base text-cream/75 leading-relaxed mb-8">
            {lang === 'en'
              ? "Video or phone. No proposals, no pressure. We listen to where you are, decide together if it makes sense to move forward, and — if it does — walk you through the next steps."
              : 'Em vídeo ou por telefone. Sem propostas, sem pressão. Ouvimos onde estás, validamos juntos se faz sentido avançar e — se for caso disso — explicamos os próximos passos.'}
          </p>

          <div class="mt-auto">
            <a
              href={schedulingUrl}
              target={schedulingIsExternal ? '_blank' : undefined}
              rel={schedulingIsExternal ? 'noopener noreferrer' : undefined}
              class="inline-flex items-center gap-2 px-6 py-3.5 rounded-full bg-cream text-teal-dark font-sans font-medium text-sm hover:bg-offwhite transition-all duration-300 group"
            >
              <i class="ri-calendar-check-line"></i>
              {lang === 'en' ? 'Book a call (30 min)' : 'Marcar conversa (30 min)'}
              <i class="ri-arrow-right-up-line transition-transform duration-200 group-hover:translate-x-1 group-hover:-translate-y-1"></i>
            </a>
            <p class="font-serif italic text-xs text-cream/50 mt-4">
              {lang === 'en' ? '30 minutes · no strings attached · you pick the time' : '30 minutos · sem compromisso · escolhes o horário'}
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact strip -->
    <div class="scroll-reveal mt-10 md:mt-12 flex flex-col sm:flex-row sm:items-center sm:justify-center gap-4 sm:gap-8 text-sm">
      <div class="flex items-center gap-2">
        <i class="ri-mail-line text-teal"></i>
        <span class="font-sans text-muted">{i.finalCta.contactPrompt}</span>
        <a
          href={`mailto:${i.finalCta.contactEmail}`}
          class="font-sans font-medium text-teal-dark hover:text-teal transition-colors"
        >
          {i.finalCta.contactEmail}
        </a>
      </div>
      <span class="hidden sm:inline text-teal-dark/30" aria-hidden="true">·</span>
      <div class="flex items-center gap-3">
        <a
          href="https://instagram.com/wavy.digital.pt"
          target="_blank"
          rel="noopener noreferrer"
          class="w-11 h-11 rounded-full bg-teal/10 flex items-center justify-center text-teal hover:bg-teal hover:text-cream transition-all duration-300"
          aria-label={lang === 'en' ? 'Wavy on Instagram' : 'Instagram da Wavy'}
        >
          <i class="ri-instagram-line text-base" aria-hidden="true"></i>
        </a>
        <a
          href="https://facebook.com/wavy.digital.pt"
          target="_blank"
          rel="noopener noreferrer"
          class="w-11 h-11 rounded-full bg-teal/10 flex items-center justify-center text-teal hover:bg-teal hover:text-cream transition-all duration-300"
          aria-label={lang === 'en' ? 'Wavy on Facebook' : 'Facebook da Wavy'}
        >
          <i class="ri-facebook-line text-base" aria-hidden="true"></i>
        </a>
      </div>
    </div>

    <!-- Manifesto final -->
    <p class="scroll-reveal mt-12 md:mt-16 text-center font-serif text-lg md:text-2xl italic text-teal-dark/80 max-w-2xl mx-auto">
      {lang === 'en'
        ? "We don't redecorate the storefront. We rebuild the foundations."
        : 'Não decoramos a montra. Reconstruímos as fundações.'}
    </p>
  </div>
</section>
