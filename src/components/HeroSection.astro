---
import { t, getLocalizedPath } from '../i18n';
import type { Lang } from '../i18n';
import { contactHref } from '../lib/env';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const ctaHref = contactHref(getLocalizedPath('/contacto', lang));
---

<section class="relative bg-offwhite pt-16 md:pt-[72px] min-h-screen flex flex-col">
  <div class="max-w-7xl mx-auto w-full px-6 md:px-10 pt-6 md:pt-8 pb-2 md:pb-4 flex-1 flex flex-col">
    <div class="flex-1 flex items-center">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center w-full">
      <!-- Text -->
      <div>
        <span class="inline-block font-sans text-xs font-medium uppercase tracking-widest text-teal bg-teal/10 px-4 py-2 rounded-full mb-6">
          {i.hero.tagline}
        </span>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-medium text-teal-dark leading-[1.05] mb-6">
          {i.hero.headline}
        </h1>
        <p class="font-sans text-base md:text-lg text-muted leading-relaxed mb-8 max-w-lg">
          {i.hero.subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 items-start">
          <a
            href={ctaHref}
            class="inline-flex items-center justify-center gap-2 font-sans font-medium text-base px-9 py-4 rounded-full bg-teal text-white hover:bg-teal-dark transition-all duration-300 whitespace-nowrap"
          >
            {i.hero.cta2}
          </a>
          <a
            href={ctaHref}
            class="inline-flex items-center justify-center gap-2 font-sans font-medium text-base px-9 py-4 rounded-full border border-teal-dark/15 text-teal-dark hover:border-teal-dark hover:bg-teal-dark/5 transition-all duration-300 whitespace-nowrap"
          >
            {i.hero.cta1}
          </a>
        </div>
        <p class="font-sans text-xs text-muted/70 mt-3">
          {i.hero.cta1Micro}
        </p>
      </div>

      <!-- Image with floating badges -->
      <div class="relative">
        <div class="relative rounded-[32px] overflow-hidden bg-cream aspect-[4/5] max-w-[640px] mx-auto">
          <img
            src="https://static.readdy.ai/image/5009dd3650e45e305981c297303673fb/2f44de33f1b530a86cf44c51d4ce6232.png"
            alt="Wavy workspace"
            class="w-full h-full object-cover object-top"
            loading="eager"
          />
        </div>

        <div class="absolute top-6 right-0 md:-right-4 bg-white/90 backdrop-blur-sm rounded-full px-4 py-2 border border-teal/10 animate-float">
          <span class="font-sans text-xs font-medium text-teal-dark">{i.hero.badge1}</span>
        </div>

        <div class="absolute top-[35%] -left-2 md:-left-6 bg-teal rounded-full px-4 py-2 animate-float-slow">
          <span class="font-sans text-xs font-medium text-white">{i.hero.badge2}</span>
        </div>

        <div class="absolute bottom-16 right-0 md:-right-4 bg-white/90 backdrop-blur-sm rounded-full px-4 py-2 border border-teal/10 animate-float" style="animation-delay: 2s">
          <span class="font-sans text-xs font-medium text-teal-dark">{i.hero.badge3}</span>
        </div>
      </div>
    </div>
    </div>

    <!-- Scroll indicator -->
    <div class="flex flex-col items-center pt-6 pb-4">
      <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-muted/50 mb-2">{i.hero.scroll}</p>
      <div class="w-8 h-8 rounded-full border border-teal/30 flex items-center justify-center animate-scroll-hint">
        <i class="ri-arrow-down-line text-teal text-sm"></i>
      </div>
    </div>
  </div>
</section>
