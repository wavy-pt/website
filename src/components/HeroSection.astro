---
import { Image } from 'astro:assets';
import { t, getLocalizedPath } from '../i18n';
import type { Lang } from '../i18n';
import { contactHref, schedulingHref, schedulingIsExternal } from '../lib/env';
import heroImage from '../assets/wavy-hero.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const ctaHref = contactHref(getLocalizedPath('/contacto', lang));
const schedulingUrl = schedulingHref(getLocalizedPath('/contacto', lang));
---

<section class="relative bg-offwhite pt-16 md:pt-[72px] min-h-screen flex flex-col">
  <div class="max-w-7xl mx-auto w-full px-6 md:px-10 pt-6 md:pt-8 pb-2 md:pb-4 flex-1 flex flex-col">
    <div class="flex-1 flex items-center">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center w-full">
      <!-- Text -->
      <div>
        <span class="inline-block font-sans text-xs font-medium uppercase tracking-widest text-teal-dark bg-teal/15 px-4 py-2 rounded-full mb-6">
          {i.hero.tagline}
        </span>
        <h1 class="font-serif text-[2.5rem] leading-[1.05] sm:text-5xl md:text-5xl lg:text-6xl xl:text-7xl font-medium text-teal-dark mb-5 md:mb-6">
          {i.hero.headline}
        </h1>
        <p class="font-sans text-base md:text-lg text-muted leading-relaxed mb-7 md:mb-8 max-w-lg">
          {i.hero.subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 items-stretch sm:items-start">
          <a
            href={schedulingUrl}
            target={schedulingIsExternal ? '_blank' : undefined}
            rel={schedulingIsExternal ? 'noopener noreferrer' : undefined}
            class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm md:text-base px-7 py-3.5 md:px-9 md:py-4 rounded-full bg-teal-dark text-cream hover:bg-teal transition-all duration-300 whitespace-nowrap"
          >
            {i.hero.cta2}
          </a>
          <a
            href={ctaHref}
            class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm md:text-base px-7 py-3.5 md:px-9 md:py-4 rounded-full border border-teal-dark/15 text-teal-dark hover:border-teal-dark hover:bg-teal-dark/5 transition-all duration-300 whitespace-nowrap"
          >
            {i.hero.cta1}
          </a>
        </div>
        <p class="font-sans text-xs text-muted mt-3">
          {i.hero.cta1Micro}
        </p>
      </div>

      <!-- Image with floating badges -->
      <div class="relative">
        <div class="relative rounded-[32px] overflow-hidden bg-cream aspect-[4/5] max-w-[640px] mx-auto">
          <Image
            src={heroImage}
            alt="Mariana ao computador — Wavy"
            class="w-full h-full object-cover object-top"
            loading="eager"
            fetchpriority="high"
            widths={[480, 640, 960, 1280]}
            sizes="(min-width: 1024px) 640px, (min-width: 640px) 50vw, 100vw"
            quality={85}
          />
        </div>

        <div class="absolute top-6 right-0 md:-right-4 bg-white/90 backdrop-blur-sm rounded-full px-4 py-2 border border-teal/10 animate-float">
          <span class="font-sans text-xs font-medium text-teal-dark">{i.hero.badge1}</span>
        </div>

        <div class="absolute top-[35%] -left-2 md:-left-6 bg-teal-dark rounded-full px-4 py-2 animate-float-slow">
          <span class="font-sans text-xs font-medium text-cream">{i.hero.badge2}</span>
        </div>

        <div class="absolute bottom-16 right-0 md:-right-4 bg-white/90 backdrop-blur-sm rounded-full px-4 py-2 border border-teal/10 animate-float" style="animation-delay: 2s">
          <span class="font-sans text-xs font-medium text-teal-dark">{i.hero.badge3}</span>
        </div>
      </div>
    </div>
    </div>

    <!-- Scroll indicator -->
    <div class="flex flex-col items-center pt-6 pb-4">
      <p class="font-sans text-[11px] uppercase tracking-[0.2em] text-muted mb-2">{i.hero.scroll}</p>
      <div class="w-8 h-8 rounded-full border border-teal/30 flex items-center justify-center animate-scroll-hint">
        <i class="ri-arrow-down-line text-teal text-sm"></i>
      </div>
    </div>
  </div>
</section>
