---
import { Image } from 'astro:assets';
import { t } from '../../i18n';
import type { Lang } from '../../i18n';
import marianaPhoto from '../../assets/IMG_7230.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).aboutPage.mariana;
---

<section class="bg-offwhite py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-14 items-center">
      <!-- Photo (à direita no desktop — a Mariana olha para o texto) -->
      <div class="relative w-full sm:w-[85%] md:w-full mx-auto aspect-[3/4] sm:aspect-[4/5] max-w-sm lg:max-w-md lg:mr-0 lg:order-2 rounded-[24px] overflow-hidden bg-teal/10">
        <Image
          src={marianaPhoto}
          alt={i.alt}
          class="absolute inset-0 w-full h-full object-cover object-top"
          loading="lazy"
          widths={[400, 600, 800]}
          sizes="(min-width: 1024px) 28rem, (min-width: 640px) 380px, 100vw"
          quality={85}
        />
      </div>

      <!-- Text (à esquerda no desktop) -->
      <div class="flex flex-col text-center lg:text-left lg:order-1">
        <p class="font-sans text-xs uppercase tracking-[0.2em] text-teal-deep mb-5 flex items-center gap-3 justify-center lg:justify-start">
          <span class="w-8 h-px bg-teal" aria-hidden="true"></span>
          {i.tag}
        </p>
        <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-teal-dark leading-[1.1] mb-6">
          {i.headline}{' '}
          <em class="text-teal font-serif italic font-medium">{i.headlineHighlight}</em>
        </h2>
        <div class="space-y-4 mb-6 text-left">
          {i.paragraphs.map((p) => (
            <p class="font-sans text-base text-muted leading-relaxed">{p}</p>
          ))}
        </div>
        <p class="font-serif text-lg italic text-teal-dark text-center lg:text-left">{i.signature}</p>
      </div>
    </div>
  </div>
</section>
