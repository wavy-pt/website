---
import { Image } from 'astro:assets';
import { t } from '../../i18n';
import type { Lang } from '../../i18n';
import heroImage from '../../assets/wavy-hero.jpg';
import bastidoresImage from '../../assets/wavy-bastidores.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).aboutPage.hero;

// Mapeamento de imageKey → imagem local (substitui URLs externas do Readdy)
const imageMap: Record<string, typeof heroImage> = {
  hero: heroImage,
  bastidores: bastidoresImage,
};

// Cores dos cards
const colorMap: Record<string, { bg: string; text: string; labelText: string; numberText: string; bodyText: string; border: string }> = {
  cream: {
    bg: 'bg-cream',
    text: 'text-teal-dark',
    labelText: 'text-teal/70',
    numberText: 'text-teal',
    bodyText: 'text-muted',
    border: 'border border-teal/10',
  },
  teal: {
    bg: 'bg-teal',
    text: 'text-cream',
    labelText: 'text-cream/70',
    numberText: 'text-cream',
    bodyText: 'text-cream/80',
    border: '',
  },
  'teal-dark': {
    bg: 'bg-teal-dark',
    text: 'text-cream',
    labelText: 'text-cream/70',
    numberText: 'text-cream',
    bodyText: 'text-cream/80',
    border: '',
  },
};

const items = i.marquee;
const row1 = items.slice(0, 5);
const row2 = items.slice(5, 10);
---

<section class="bg-offwhite pt-24 pb-6 md:pt-32 md:pb-10 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <p class="font-sans text-xs uppercase tracking-[0.2em] text-teal mb-6 flex items-center gap-3">
        <span class="w-8 h-px bg-teal" aria-hidden="true"></span>
        {i.tag}
      </p>

      <div class="flex flex-col gap-4 mb-10 md:mb-12">
        <h1 class="font-serif text-[2.25rem] sm:text-4xl md:text-5xl lg:text-6xl font-medium text-teal-dark leading-[1.1] max-w-xl">
          {i.headline}
          <br />
          <em class="text-teal font-serif italic font-medium">{i.headlineHighlight}</em>
        </h1>
        <p class="font-sans text-base md:text-lg text-muted leading-relaxed max-w-xl">
          {i.subtitle}
        </p>
      </div>
    </div>
  </div>

  <!-- Marquee rows -->
  <div class="relative -mx-4 md:-mx-8">
    <!-- Row 1: animate-marquee-left -->
    <div class="flex gap-4 md:gap-5 mb-3 md:mb-4 w-max animate-marquee-left">
      {[...row1, ...row1].map((item) => {
        const c = colorMap[item.cardColor || 'cream'];
        if (item.type === 'image') {
          const img = imageMap[item.imageKey || 'bastidores'];
          return (
            <div class="shrink-0 w-52 sm:w-60 md:w-72 lg:w-80 h-32 sm:h-36 md:h-40 lg:h-48 rounded-2xl overflow-hidden relative">
              <Image src={img} alt="" class="w-full h-full object-cover object-top" loading="lazy" widths={[320, 480]} sizes="320px" quality={75} />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent" aria-hidden="true"></div>
            </div>
          );
        }
        if (item.type === 'stat') {
          return (
            <div class:list={[
              'shrink-0 w-40 sm:w-44 md:w-52 lg:w-60 h-32 sm:h-36 md:h-40 lg:h-48 rounded-2xl flex flex-col justify-end p-4 sm:p-5 md:p-6',
              c.bg, c.text, c.border,
            ]}>
              <span class:list={['font-sans text-xs uppercase tracking-[0.15em] mb-2', c.labelText]}>{item.label}</span>
              <span class:list={['font-serif text-3xl sm:text-4xl md:text-5xl font-medium', c.numberText]}>{item.number}</span>
            </div>
          );
        }
        return (
          <div class:list={[
            'shrink-0 w-44 sm:w-52 md:w-64 lg:w-72 h-32 sm:h-36 md:h-40 lg:h-48 rounded-2xl flex flex-col justify-end p-4 sm:p-5 md:p-6',
            c.bg, c.text, c.border,
          ]}>
            <h4 class="font-serif text-base sm:text-lg md:text-xl font-medium mb-1">{item.title}</h4>
            <p class:list={['font-sans text-xs md:text-sm leading-relaxed', c.bodyText]}>{item.body}</p>
          </div>
        );
      })}
    </div>

    <!-- Row 2: animate-marquee-right -->
    <div class="flex gap-4 md:gap-5 w-max animate-marquee-right">
      {[...row2, ...row2].map((item) => {
        const c = colorMap[item.cardColor || 'cream'];
        if (item.type === 'image') {
          const img = imageMap[item.imageKey || 'bastidores'];
          return (
            <div class="shrink-0 w-52 sm:w-60 md:w-72 lg:w-80 h-32 sm:h-36 md:h-40 lg:h-48 rounded-2xl overflow-hidden relative">
              <Image src={img} alt="" class="w-full h-full object-cover object-top" loading="lazy" widths={[320, 480]} sizes="320px" quality={75} />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent" aria-hidden="true"></div>
            </div>
          );
        }
        if (item.type === 'stat') {
          return (
            <div class:list={[
              'shrink-0 w-40 sm:w-44 md:w-52 lg:w-60 h-32 sm:h-36 md:h-40 lg:h-48 rounded-2xl flex flex-col justify-end p-4 sm:p-5 md:p-6',
              c.bg, c.text, c.border,
            ]}>
              <span class:list={['font-sans text-xs uppercase tracking-[0.15em] mb-2', c.labelText]}>{item.label}</span>
              <span class:list={['font-serif text-3xl sm:text-4xl md:text-5xl font-medium', c.numberText]}>{item.number}</span>
            </div>
          );
        }
        return (
          <div class:list={[
            'shrink-0 w-44 sm:w-52 md:w-64 lg:w-72 h-32 sm:h-36 md:h-40 lg:h-48 rounded-2xl flex flex-col justify-end p-4 sm:p-5 md:p-6',
            c.bg, c.text, c.border,
          ]}>
            <h4 class="font-serif text-base sm:text-lg md:text-xl font-medium mb-1">{item.title}</h4>
            <p class:list={['font-sans text-xs md:text-sm leading-relaxed', c.bodyText]}>{item.body}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
