---
import { Image } from 'astro:assets';
import { t, getLocalizedPath } from '../../i18n';
import type { Lang } from '../../i18n';
import ctaImage from '../../assets/CTA.jpg';
import { schedulingHref, schedulingIsExternal } from '../../lib/env';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).aboutPage.cta;
const contactHref = schedulingHref(getLocalizedPath('/contacto', lang));
---

<section class="bg-white py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 md:gap-5">
        <!-- Image card -->
        <div class="lg:col-span-7 relative rounded-[28px] overflow-hidden min-h-[300px] sm:min-h-[360px] md:min-h-[460px]">
          <Image
            src={ctaImage}
            alt={i.imageAlt}
            class="absolute inset-0 w-full h-full object-cover object-center"
            loading="lazy"
            widths={[640, 900, 1280]}
            sizes="(min-width: 1024px) 58vw, 100vw"
            quality={85}
          />
        </div>

        <!-- Right column -->
        <div class="lg:col-span-5 flex flex-col gap-4 md:gap-5">
          <!-- Text card + button "Agendar conversa" -->
          <div class="flex-1 bg-cream rounded-[28px] shadow-[0_10px_30px_-14px_rgba(28,60,60,0.16)] p-6 sm:p-7 md:p-8 flex flex-col justify-between gap-6">
            <div>
              <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-medium text-teal-dark leading-[1.1] mb-3 md:mb-4">
                {i.headline}
                <br />
                <em class="text-teal font-serif italic font-medium">{i.headlineHighlight}</em>
              </h2>
              <p class="font-sans text-base text-muted leading-relaxed max-w-sm">
                {i.subtitle}
              </p>
            </div>
            <a
              href={contactHref}
              target={schedulingIsExternal ? '_blank' : undefined}
              rel={schedulingIsExternal ? 'noopener noreferrer' : undefined}
              class="inline-flex items-center justify-center gap-2 self-start font-sans font-medium text-sm px-7 py-3.5 md:px-8 md:py-4 rounded-full bg-teal-dark text-cream hover:bg-teal transition-all duration-300 whitespace-nowrap"
            >
              {i.button}
              <i class="ri-arrow-right-line" aria-hidden="true"></i>
            </a>
          </div>

          <!-- Two cards: social + email -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-5">
            <!-- Social card -->
            <div class="bg-teal-deep rounded-[28px] p-6 sm:p-7 flex flex-col justify-between gap-5 min-h-[150px]">
              <div>
                <p class="font-sans text-xs uppercase tracking-[0.15em] text-cream/90 mb-2">
                  {i.socialLabel}
                </p>
                <p class="font-serif text-lg md:text-xl text-cream font-medium leading-snug">
                  {i.socialText}
                </p>
              </div>
              <div class="flex gap-3">
                <a
                  href="https://instagram.com/wavy.digital.pt"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Instagram da Wavy"
                  class="w-11 h-11 rounded-full bg-cream/15 hover:bg-cream/25 flex items-center justify-center text-cream transition-colors"
                >
                  <i class="ri-instagram-line text-lg" aria-hidden="true"></i>
                </a>
                <a
                  href="https://facebook.com/wavy.digital.pt"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Facebook da Wavy"
                  class="w-11 h-11 rounded-full bg-cream/15 hover:bg-cream/25 flex items-center justify-center text-cream transition-colors"
                >
                  <i class="ri-facebook-line text-lg" aria-hidden="true"></i>
                </a>
              </div>
            </div>

            <!-- Email card -->
            <div class="bg-teal-deep rounded-[28px] p-6 sm:p-7 flex flex-col justify-between gap-5 min-h-[150px]">
              <div>
                <p class="font-sans text-xs uppercase tracking-[0.15em] text-cream/90 mb-2">
                  {i.emailLabel}
                </p>
                <p class="font-serif text-lg md:text-xl text-cream font-medium leading-snug">
                  {i.emailText}
                </p>
              </div>
              <a
                href="mailto:geral@wavy.pt"
                class="inline-flex items-center gap-2 font-sans font-medium text-sm text-cream hover:text-cream/90 transition-colors"
              >
                <i class="ri-mail-line text-base" aria-hidden="true"></i>
                {i.email}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {i.manifesto && (
    <div class="max-w-7xl mx-auto px-6 md:px-10 mt-12 md:mt-16">
      <p class="scroll-reveal text-center font-serif text-lg md:text-2xl italic text-teal-dark/80 max-w-2xl mx-auto">
        {i.manifesto}
      </p>
    </div>
  )}
</section>
