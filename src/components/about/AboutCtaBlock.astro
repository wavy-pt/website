---
import { Image } from 'astro:assets';
import { t, getLocalizedPath } from '../../i18n';
import type { Lang } from '../../i18n';
import bastidoresImage from '../../assets/wavy-bastidores.jpg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).aboutPage.cta;
const contactHref = getLocalizedPath('/contacto', lang);
---

<section class="bg-cream py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 md:gap-5 rounded-[28px] overflow-hidden">
        <!-- Image card -->
        <div class="lg:col-span-7 relative rounded-[28px] overflow-hidden min-h-[260px] sm:min-h-[300px] md:min-h-[380px]">
          <Image
            src={bastidoresImage}
            alt="Wavy studio"
            class="absolute inset-0 w-full h-full object-cover object-top"
            loading="lazy"
            widths={[640, 900, 1280]}
            sizes="(min-width: 1024px) 58vw, 100vw"
            quality={85}
          />
          <div class="absolute inset-0 bg-gradient-to-t from-teal-dark/30 via-transparent to-transparent" aria-hidden="true"></div>
        </div>

        <!-- Right column -->
        <div class="lg:col-span-5 flex flex-col gap-4 md:gap-5">
          <!-- Text card -->
          <div class="flex-1 bg-offwhite rounded-[28px] p-6 sm:p-7 md:p-8 flex flex-col justify-between">
            <div>
              <h2 class="font-serif text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-medium text-teal-dark leading-[1.1] mb-3 md:mb-4">
                {i.headline}
                <br />
                <em class="text-teal font-serif italic font-medium">{i.headlineHighlight}</em>
              </h2>
              <p class="font-sans text-base text-muted leading-relaxed max-w-sm">
                {i.subtitle}
              </p>
            </div>
          </div>

          <!-- Button card -->
          <div class="bg-teal rounded-[28px] p-6 sm:p-7 md:p-8 flex flex-col sm:flex-row lg:flex-col items-start sm:items-center lg:items-start justify-between gap-4">
            <div>
              <p class="font-sans text-xs uppercase tracking-[0.15em] text-cream/70 mb-2">
                {i.ctaLabel}
              </p>
              <p class="font-serif text-xl md:text-2xl text-cream font-medium leading-snug">
                {i.ctaText}
              </p>
            </div>
            <a
              href={contactHref}
              class="inline-flex items-center justify-center gap-2 font-sans font-medium text-sm px-7 py-3.5 md:px-8 md:py-4 rounded-full bg-cream text-teal-dark hover:bg-offwhite transition-all duration-300 whitespace-nowrap shrink-0"
            >
              {i.button}
              <i class="ri-arrow-right-line" aria-hidden="true"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
