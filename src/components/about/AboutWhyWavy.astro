---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).aboutPage.whyWavy;
---

<section class="relative bg-white overflow-hidden">
  <!-- Conteúdo (texto creme sobre o verde) -->
  <div class="relative z-10 max-w-2xl mx-auto px-6 md:px-10 pt-[200px] sm:pt-[250px] md:pt-[330px] pb-20 md:pb-28 text-center">
    <div class="scroll-reveal">
      <h2 class="font-serif text-4xl md:text-5xl font-medium text-teal-dark leading-[1.1] mb-8">
        {i.headline}{' '}
        <em class="text-teal font-serif italic font-medium">{i.headlineHighlight}</em>
      </h2>
      <div class="space-y-5 text-left">
        {i.paragraphs.map((p) => (
          <p class="font-sans text-base md:text-lg text-muted leading-relaxed">{p}</p>
        ))}
      </div>
    </div>
  </div>

  <!-- Onda creme em S no topo: o creme do manifesto desce para o verde, mais funda à direita -->
  <div
    class="absolute inset-x-0 top-0 leading-[0] pointer-events-none [filter:drop-shadow(0_6px_16px_rgba(28,60,60,0.16))]"
    aria-hidden="true"
  >
    <svg class="block w-full h-[200px] sm:h-[270px] md:h-[350px]" viewBox="0 0 1440 350" preserveAspectRatio="none">
      <path fill="#F0EDE4" d="M0,0 L0,245 C200,266 360,260 520,190 C620,135 665,85 745,85 C1000,85 1160,235 1440,305 L1440,0 Z" />
    </svg>
  </div>
</section>
