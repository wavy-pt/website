---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang).aboutPage.differenceTable;
---

<section class="bg-offwhite py-14 md:py-20">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="scroll-reveal">
      <!-- Header -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-12 mb-10 md:mb-14">
        <div>
          <p class="font-sans text-xs uppercase tracking-[0.2em] text-teal mb-5 flex items-center gap-3">
            <span class="w-8 h-px bg-teal" aria-hidden="true"></span>
            {i.label}
          </p>
          <h2 class="font-serif text-[2rem] sm:text-4xl md:text-5xl font-medium text-teal-dark leading-[1.1]">
            {i.headline}
            <br />
            <em class="text-teal font-serif italic font-medium">{i.headlineHighlight}</em>
          </h2>
        </div>
        <div class="flex items-end">
          <p class="font-sans text-base text-muted leading-relaxed max-w-md">
            {i.subtitle}
          </p>
        </div>
      </div>

      <!-- Desktop Table -->
      <div class="hidden lg:block bg-cream rounded-[24px] overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full min-w-[680px]">
            <thead>
              <tr class="border-b border-teal-dark/10">
                {i.headers.map((h, idx) => (
                  <th
                    class:list={[
                      'text-left font-sans text-xs uppercase tracking-widest px-6 py-4',
                      idx === 0 ? 'text-teal-dark w-[140px]' : '',
                      idx === 3 ? 'bg-teal text-cream rounded-tl-[20px] rounded-tr-[20px]' : 'text-muted',
                    ]}
                  >
                    {idx === 3 ? (
                      <span class="font-serif text-lg font-medium normal-case tracking-normal">{h}</span>
                    ) : (
                      h
                    )}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody>
              {i.rows.map((row) => (
                <tr class="border-t border-teal-dark/10">
                  <td class="font-sans text-sm font-medium text-teal-dark px-6 py-4 w-[140px]">
                    {row.dim}
                  </td>
                  <td class="font-sans text-sm text-muted px-6 py-4">
                    {row.agency}
                  </td>
                  <td class="font-sans text-sm text-muted px-6 py-4">
                    {row.freelance}
                  </td>
                  <td class="font-sans text-sm font-medium text-teal-dark bg-teal/10 px-6 py-4">
                    {row.wavy}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Mobile Cards -->
      <div class="lg:hidden space-y-3">
        {i.rows.map((row) => (
          <div class="bg-cream rounded-2xl p-5">
            <p class="font-sans text-xs uppercase tracking-widest text-teal mb-3">
              {row.dim}
            </p>
            <div class="space-y-3">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-muted/20 flex items-center justify-center shrink-0" aria-hidden="true">
                  <span class="font-sans text-xs text-muted font-medium">A</span>
                </div>
                <div>
                  <span class="font-sans text-[10px] uppercase tracking-wider text-muted block mb-0.5">{i.headers[1]}</span>
                  <span class="font-sans text-sm text-teal-dark">{row.agency}</span>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-muted/20 flex items-center justify-center shrink-0" aria-hidden="true">
                  <span class="font-sans text-xs text-muted font-medium">F</span>
                </div>
                <div>
                  <span class="font-sans text-[10px] uppercase tracking-wider text-muted block mb-0.5">{i.headers[2]}</span>
                  <span class="font-sans text-sm text-teal-dark">{row.freelance}</span>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-full bg-teal flex items-center justify-center shrink-0" aria-hidden="true">
                  <span class="font-sans text-xs text-cream font-medium">W</span>
                </div>
                <div>
                  <span class="font-sans text-[10px] uppercase tracking-wider text-teal block mb-0.5">{i.headers[3]}</span>
                  <span class="font-sans text-sm font-medium text-teal-dark">{row.wavy}</span>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
