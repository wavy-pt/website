---
/**
 * Schema.org structured data for Wavy.
 * Emits a JSON-LD <script> tag so search engines AND generative engines
 * (Google AI Overviews, ChatGPT, Perplexity, etc.) understand what the
 * business is, where it operates, who runs it, and what it offers.
 *
 * Usa @graph para ligar a Organização, os Serviços e o WebSite numa só
 * estrutura coerente (entidade clara = melhor SEO local + GEO/AIO).
 */
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://wavy.pt';

const organization = {
  '@type': 'ProfessionalService',
  '@id': `${site}/#organization`,
  name: 'Wavy',
  alternateName: 'Wavy, Direção e Marketing Digital',
  url: site,
  logo: `${site}/logo-wavy.svg`,
  image: `${site}/og-image.jpg`,
  description:
    'Direção e marketing digital para negócios com história, na Zona Oeste e Grande Lisboa. Estratégia, websites, redes sociais e SEO local.',
  founder: {
    '@type': 'Person',
    name: 'Mariana Antunes',
    jobTitle: 'Fundadora e Diretora',
  },
  email: 'geral@wavy.pt',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Mafra',
    addressRegion: 'Lisboa',
    addressCountry: 'PT',
  },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Mafra' },
    { '@type': 'AdministrativeArea', name: 'Samora Correia' },
    { '@type': 'Place', name: 'Zona Oeste' },
    { '@type': 'Place', name: 'Grande Lisboa' },
    { '@type': 'Country', name: 'Portugal' },
  ],
  knowsAbout: [
    'Marketing Digital',
    'Direção Digital',
    'Estratégia Digital',
    'Desenvolvimento de Websites',
    'Gestão de Redes Sociais',
    'SEO Local',
    'Google Business Profile',
    'Identidade Visual',
  ],
  serviceType: [
    'Diagnóstico Estratégico',
    'Website e Identidade Estratégica',
    'Gestão de Redes Sociais e SEO Local',
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Serviços Wavy',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'O Raio-X',
          description:
            'Diagnóstico estratégico digital. Ponto de partida de qualquer projeto: analisa o negócio e define o caminho.',
          url: `${site}/servicos#servico-01`,
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'A Obra',
          description:
            'Identidade visual e/ou website. Construção das fundações digitais do negócio.',
          url: `${site}/servicos#servico-02`,
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'A Direção',
          description:
            'Gestão contínua de redes sociais e SEO local, com estratégia e medição de resultados.',
          url: `${site}/servicos#servico-03`,
        },
      },
    ],
  },
  sameAs: [
    'https://instagram.com/wavy.digital.pt',
    'https://facebook.com/wavy.digital.pt',
  ],
  priceRange: '€€',
  inLanguage: ['pt-PT', 'en'],
};

const website = {
  '@type': 'WebSite',
  '@id': `${site}/#website`,
  url: site,
  name: 'Wavy',
  description:
    'Direção e marketing digital para negócios com história, na Zona Oeste e Grande Lisboa.',
  inLanguage: ['pt-PT', 'en'],
  publisher: { '@id': `${site}/#organization` },
};

const schema = {
  '@context': 'https://schema.org',
  '@graph': [organization, website],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
