---
import { t, getLocalizedPath } from '../i18n';
import type { Lang } from '../i18n';
import { isProd, schedulingHref, schedulingIsExternal } from '../lib/env';
import { switchLangPath as resolveSwitchPath } from '../lib/slugs';

interface Props {
  lang: Lang;
  /**
   * Estado inicial do header sobre uma hero com imagem:
   *   - `false` (default) → opaco, texto teal-dark (comportamento normal).
   *   - `true`           → fundo transparente, texto cream (sobre imagem ESCURA).
   *                        Ao scroll, ganha bg-offwhite e texto volta a teal-dark.
   *   - `'light'`        → fundo transparente, texto fica teal-dark (sobre imagem CLARA).
   *                        Ao scroll, ganha bg-offwhite (texto mantém-se).
   */
  transparent?: boolean | 'light';
}

const { lang, transparent = false } = Astro.props;

// Helpers internos:
//   bgIsTransparent  → o fundo é transparente no topo (true e 'light').
//   usesLightText    → o texto/logo invertem para cream (só no modo `true`).
const bgIsTransparent = transparent !== false;
const usesLightText = transparent === true;
const i = t(lang);
const otherLang = lang === 'pt' ? 'en' : 'pt';

// Navegação. Páginas com wip:true ficam escondidas em produção (nenhuma de momento).
const allNavLinks = [
  { label: i.nav.home, to: getLocalizedPath('/', lang), wip: false },
  { label: i.nav.services, to: getLocalizedPath('/servicos', lang), wip: false },
  { label: i.nav.about, to: getLocalizedPath('/sobre', lang), wip: false },
  { label: i.nav.cases, to: getLocalizedPath('/casos', lang), wip: false },
  { label: i.nav.contact, to: getLocalizedPath('/contacto', lang), wip: false },
];

const navLinks = isProd ? allNavLinks.filter((l) => !l.wip) : allNavLinks;
const ctaHref = schedulingHref(getLocalizedPath('/contacto', lang));

const currentPath = Astro.url.pathname;
const switchLangPath = resolveSwitchPath(currentPath, otherLang);

// Página atual. Normaliza a barra final para o destaque funcionar tanto em dev
// como no build estático da Vercel (que serve "/sobre/" com barra final).
const normalizePath = (p: string) => p.replace(/\/+$/, '') || '/';
const isCurrent = (to: string) => normalizePath(currentPath) === normalizePath(to);
---

<header
  id="site-header"
  data-transparent={bgIsTransparent ? 'true' : 'false'}
  data-state="top"
  class:list={[
    'group/header fixed top-0 left-0 right-0 z-50 transition-all duration-300',
    bgIsTransparent ? 'bg-transparent' : 'bg-offwhite',
  ]}
>
  <div class="max-w-7xl mx-auto px-6 md:px-10 flex items-center justify-between h-16 md:h-[72px]">
    <a href={getLocalizedPath('/', lang)} id="header-logo" class="flex items-center shrink-0">
      <img
        src="/logo-wavy-tight.svg"
        alt="Wavy"
        width="95"
        height="40"
        class:list={[
          'h-9 md:h-10 w-auto transition-[filter] duration-300',
          // Quando navbar é transparente E está no topo → logo branco
          // Quando scrolled → volta à cor original (sem filtro)
          usesLightText && 'brightness-0 invert group-data-[state=scrolled]/header:brightness-100 group-data-[state=scrolled]/header:invert-0',
        ]}
      />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-8">
      {navLinks.map((link) => {
        const isActive = isCurrent(link.to);
        return (
          <a
            href={link.to}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'font-sans text-sm transition-colors duration-200 whitespace-nowrap',
              // Não transparent: comportamento original (sempre teal-dark)
              !usesLightText && (isActive ? 'text-teal-dark font-medium' : 'text-teal-dark/70 hover:text-teal-dark'),
              // Transparent: cor depende do state do header (top → cream, scrolled → teal-dark)
              usesLightText && (isActive ? 'font-medium' : ''),
              usesLightText && (isActive
                ? 'text-cream group-data-[state=scrolled]/header:text-teal-dark'
                : 'text-cream/85 hover:text-cream group-data-[state=scrolled]/header:text-teal-dark/70 group-data-[state=scrolled]/header:hover:text-teal-dark'),
            ]}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href={ctaHref}
        target={schedulingIsExternal ? '_blank' : undefined}
        rel={schedulingIsExternal ? 'noopener noreferrer' : undefined}
        class="inline-flex items-center gap-2 font-sans text-sm font-medium bg-teal-dark text-cream px-5 py-2.5 rounded-full hover:bg-teal transition-colors duration-200 whitespace-nowrap animate-pulse-ring"
      >
        <i class="ri-calendar-check-line text-base"></i>
        {i.nav.diagnosis}
      </a>
      <a
        href={switchLangPath}
        class:list={[
          'font-sans text-sm transition-colors whitespace-nowrap ml-2',
          !usesLightText && 'text-teal-dark/70 hover:text-teal-dark',
          usesLightText && 'text-cream/85 hover:text-cream group-data-[state=scrolled]/header:text-teal-dark/70 group-data-[state=scrolled]/header:hover:text-teal-dark',
        ]}
      >
        <span class:list={[
          !usesLightText && lang === 'pt' && 'text-teal-dark font-medium',
          usesLightText && lang === 'pt' && 'font-medium text-cream group-data-[state=scrolled]/header:text-teal-dark',
        ]}>PT</span>
        <span class:list={[
          'mx-1.5',
          !usesLightText && 'text-teal-dark/30',
          usesLightText && 'text-cream/40 group-data-[state=scrolled]/header:text-teal-dark/30',
        ]} aria-hidden="true">|</span>
        <span class:list={[
          !usesLightText && lang === 'en' && 'text-teal-dark font-medium',
          usesLightText && lang === 'en' && 'font-medium text-cream group-data-[state=scrolled]/header:text-teal-dark',
        ]}>EN</span>
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="mobile-toggle"
      class:list={[
        'lg:hidden w-11 h-11 flex items-center justify-center transition-colors',
        !usesLightText && 'text-teal-dark',
        usesLightText && 'text-cream group-data-[state=scrolled]/header:text-teal-dark',
      ]}
      aria-label={lang === 'en' ? 'Open menu' : 'Abrir menu'}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <i id="menu-icon" class="ri-menu-3-line text-xl" aria-hidden="true"></i>
    </button>
  </div>
</header>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  tabindex="-1"
  class="fixed inset-0 z-40 bg-offwhite flex flex-col items-center justify-center transition-all duration-200 lg:hidden opacity-0 pointer-events-none focus:outline-none"
  role="dialog"
  aria-modal="true"
  aria-label={lang === 'en' ? 'Navigation menu' : 'Menu de navegação'}
>
  <nav class="flex flex-col items-center gap-6">
    <a href={getLocalizedPath('/', lang)} class="mb-2 py-2">
      <img src="/logo-wavy-tight.svg" alt="Wavy" class="h-12 w-auto" />
    </a>
    {navLinks.map((link) => (
      <a
        href={link.to}
        aria-current={isCurrent(link.to) ? 'page' : undefined}
        class:list={[
          'font-serif text-2xl py-2 px-5 transition-colors',
          isCurrent(link.to)
            ? 'text-teal font-medium bg-teal/10 rounded-full'
            : 'text-teal-dark hover:text-teal',
        ]}
      >
        {link.label}
      </a>
    ))}
    <a
      href={ctaHref}
      target={schedulingIsExternal ? '_blank' : undefined}
      rel={schedulingIsExternal ? 'noopener noreferrer' : undefined}
      class="font-sans text-lg bg-teal-dark text-cream px-6 py-3 rounded-full"
    >
      {i.nav.diagnosis}
    </a>
    <a
      href={switchLangPath}
      class="font-sans text-base text-teal-dark/70 hover:text-teal-dark transition-colors mt-2 py-3 px-4"
    >
      {lang === 'pt' ? 'Switch to English' : 'Mudar para Português'}
    </a>
  </nav>
</div>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');
  const headerLogo = document.getElementById('header-logo');
  let open = false;

  function setMenu(nextOpen: boolean) {
    open = nextOpen;
    if (open) {
      menu?.classList.remove('opacity-0', 'pointer-events-none');
      menu?.classList.add('opacity-100', 'pointer-events-auto');
      icon?.classList.remove('ri-menu-3-line');
      icon?.classList.add('ri-close-line');
      toggle?.setAttribute('aria-expanded', 'true');
      toggle?.setAttribute('aria-label', document.documentElement.lang === 'en' ? 'Close menu' : 'Fechar menu');
      document.body.style.overflow = 'hidden';
      // Menu aberto: esconde o logo do header (fica só o logo central do menu)
      headerLogo?.classList.add('opacity-0', 'pointer-events-none');
      // Foco no contentor do menu (sem anel visível num link) para leitores de ecrã
      menu?.focus();
    } else {
      menu?.classList.add('opacity-0', 'pointer-events-none');
      menu?.classList.remove('opacity-100', 'pointer-events-auto');
      icon?.classList.add('ri-menu-3-line');
      icon?.classList.remove('ri-close-line');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', document.documentElement.lang === 'en' ? 'Open menu' : 'Abrir menu');
      document.body.style.overflow = '';
      headerLogo?.classList.remove('opacity-0', 'pointer-events-none');
    }
  }

  toggle?.addEventListener('click', () => setMenu(!open));

  // Esc fecha o menu mobile
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && open) {
      setMenu(false);
      toggle?.focus();
    }
  });

  // Fechar menu ao clicar em link interno
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      if (open) setMenu(false);
    });
  });

  const header = document.getElementById('site-header');
  const isTransparent = header?.getAttribute('data-transparent') === 'true';

  function updateHeaderOnScroll() {
    if (!header) return;
    const scrolled = window.scrollY > 20;

    // data-state controla cores dos links via group-data-[state=...]
    header.dataset.state = scrolled ? 'scrolled' : 'top';

    if (isTransparent) {
      // Modo transparent: no topo é totalmente transparente; ao scroll, ganha fundo opaco
      if (scrolled) {
        header.classList.remove('bg-transparent');
        header.classList.add('bg-offwhite/95', 'backdrop-blur-sm', 'shadow-sm');
      } else {
        header.classList.add('bg-transparent');
        header.classList.remove('bg-offwhite/95', 'backdrop-blur-sm', 'shadow-sm');
      }
    } else {
      // Modo default: já tem bg-offwhite; adiciona blur/shadow ao scroll
      if (scrolled) {
        header.classList.add('bg-offwhite/95', 'backdrop-blur-sm');
      } else {
        header.classList.remove('bg-offwhite/95', 'backdrop-blur-sm');
      }
    }
  }

  // Initial state + on scroll
  updateHeaderOnScroll();
  window.addEventListener('scroll', updateHeaderOnScroll, { passive: true });
</script>
