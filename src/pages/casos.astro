---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import CasesHero from '../components/cases/CasesHero.astro';
import CasesTransparency from '../components/cases/CasesTransparency.astro';
import CaseStudy from '../components/cases/CaseStudy.astro';
import CasesCta from '../components/cases/CasesCta.astro';
import { isProd } from '../lib/env';

if (isProd) {
  return Astro.redirect('/', 308);
}
---

<Layout
  title="Casos · Transformações Digitais Reais | Wavy"
  description="Três projetos reais de direção digital: renovação de marca (Vera Barata), identidade de raiz (ADDS) e fundação estratégica (marca alimentar familiar)."
>
  <CasesHero lang="pt" />
  <CasesTransparency lang="pt" />
  <CaseStudy lang="pt" index={0} />
  <CaseStudy lang="pt" index={1} />
  <CaseStudy lang="pt" index={2} />
  <CasesCta lang="pt" />
  <ScrollReveal />
</Layout>
