---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import CasesHero from '../components/cases/CasesHero.astro';
import CaseStudy from '../components/cases/CaseStudy.astro';
import CasesCta from '../components/cases/CasesCta.astro';
import { isProd } from '../lib/env';

if (isProd) {
  return Astro.redirect('/', 308);
}
---

<Layout
  title="Casos · Histórias de Transformação Digital · Wavy"
  description="Histórias de transformação digital: negócios que confiaram na Wavy para crescer online com estratégia e consistência."
>
  <CasesHero lang="pt" />
  <CaseStudy lang="pt" index={0} />
  <CaseStudy lang="pt" index={1} />
  <CaseStudy lang="pt" index={2} />
  <CasesCta lang="pt" />
  <ScrollReveal />
</Layout>
