---
import Layout from '../layouts/Layout.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import ServicesHero from '../components/services/ServicesHeroAlt.astro';
import ServicesMethod from '../components/services/ServicesMethod.astro';
import ServicesJourney from '../components/services/ServicesJourneyAlt.astro';
import ServicesCtaBlock from '../components/services/ServicesCtaBlock.astro';
import ServicesManifesto from '../components/services/ServicesManifesto.astro';
import FaqSection from '../components/FaqSection.astro';
import { t } from '../i18n';
import { isProd } from '../lib/env';

// Em produção, página ainda não está pronta — redirect para homepage.
// Em development, mostra o desenvolvimento em curso.
if (isProd) {
  return Astro.redirect('/', 308);
}
---

<Layout
  title="Serviços · Raio-X, Obra, Direção | Wavy Marketing Digital"
  description="Três serviços, um método. Raio-X desde 350€, Obra desde 1.500€, Direção desde 750€/mês. Preços públicos, sem fidelizações longas. Para PMEs consolidadas."
  headerTransparent="light"
>
  <ServicesHero lang="pt" />
  <ServicesMethod lang="pt" />
  <ServicesJourney lang="pt" />
  <ServicesCtaBlock lang="pt" />
  <FaqSection lang="pt" faq={t('pt').servicesPage.faq} />
  <ServicesManifesto lang="pt" />
  <ScrollReveal />
</Layout>
