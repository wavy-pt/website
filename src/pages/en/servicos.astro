  description="Two paths to build your digital presence. Foundation and monthly social media management, with Wavy."
>
  <ServicesHero lang="en" />
  <ServicesCards lang="en" />
  <ServicesAddons lang="en" />
  <ServicesProcess lang="en" />
  <ServicesCtaBlock lang="en" />
  <ScrollReveal />
</Layout>
