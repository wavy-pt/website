---
import Layout from '../../layouts/Layout.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import CasesHero from '../../components/cases/CasesHero.astro';
import CaseStudy from '../../components/cases/CaseStudy.astro';
import CasesCta from '../../components/cases/CasesCta.astro';
import { isProd } from '../../lib/env';

if (isProd) {
  return Astro.redirect('/en', 308);
}
---

<Layout
  title="Cases · Digital Transformation Stories · Wavy"
  description="Digital transformation stories: businesses that trusted Wavy to grow online with strategy and consistency."
>
  <CasesHero lang="en" />
  <CaseStudy lang="en" index={0} />
  <CaseStudy lang="en" index={1} />
  <CaseStudy lang="en" index={2} />
  <CaseStudy lang="en" index={3} />
  <CaseStudy lang="en" index={4} />
  <CasesCta lang="en" />
  <ScrollReveal />
</Layout>
