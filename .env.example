# Copy to .env.development (already committed) or .env.production
# Vercel: set PUBLIC_ENV in the dashboard per environment

# "production" hides WIP pages, "development" shows everything + dev banner + noindex
PUBLIC_ENV=development

# Google Analytics 4 measurement ID. Leave empty to disable analytics entirely.
# Only loaded after the user accepts the cookie banner (production only).
PUBLIC_GA_ID=
